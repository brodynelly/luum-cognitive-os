#!/usr/bin/env python3
"""CLI for ADR-205 Run Flight Recorder."""
from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
if str(ROOT) not in sys.path:
    sys.path.insert(0, str(ROOT))

from lib.trace_joiner import build_run_trace, repo_root  # noqa: E402


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description="Join Cognitive OS metric streams into a bounded run trace.")
    parser.add_argument("--project-dir", type=Path, default=repo_root())
    parser.add_argument("--run-id")
    parser.add_argument("--session-id")
    parser.add_argument("--limit", type=int, help="Maximum rows to read per stream")
    parser.add_argument("--no-write", action="store_true")
    parser.add_argument("--json", action="store_true")
    return parser


def main() -> int:
    args = build_parser().parse_args()
    payload = build_run_trace(
        args.project_dir,
        run_id=args.run_id,
        session_id=args.session_id,
        limit_per_stream=args.limit,
        write=not args.no_write,
    )
    if args.json:
        print(json.dumps(payload, indent=2, sort_keys=True))
    else:
        print(
            "run trace: "
            f"run_id={payload['run_id']} events={payload['event_count']} "
            f"status={payload['final_status']}"
        )
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
