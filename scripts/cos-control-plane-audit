#!/usr/bin/env python3
"""Run manifest-declared control-plane audits by lane.

This is the scheduler/aggregator layer for ADR-239+ follow-up audits. It is
read-only: commands declared here must report JSON and must not mutate state.
"""
from __future__ import annotations

import argparse
import json
import subprocess
import time
from pathlib import Path
from typing import Any

import yaml

SCHEMA_VERSION = "control-plane-audit-run/v1"
DEFAULT_MANIFEST = Path("manifests/control-plane-audits.yaml")


def git_root(start: Path) -> Path:
    proc = subprocess.run(["git", "-C", str(start), "rev-parse", "--show-toplevel"], text=True, capture_output=True, check=False)
    if proc.returncode == 0 and proc.stdout.strip():
        return Path(proc.stdout.strip()).resolve()
    return start.resolve()


def load_yaml(path: Path) -> dict[str, Any]:
    if not path.exists():
        return {}
    return yaml.safe_load(path.read_text(encoding="utf-8")) or {}


def run_audit(root: Path, audit_id: str, spec: dict[str, Any], timeout: float) -> dict[str, Any]:
    cmd = [str(part) for part in spec.get("command", [])]
    started = time.time()
    if spec.get("mutates") is not False:
        return {
            "id": audit_id,
            "status": "block",
            "returncode": None,
            "elapsed_seconds": 0,
            "summary": {"block": 1, "warn": 0, "findings": 1},
            "findings": [{"severity": "block", "code": "mutating-audit-not-allowed", "message": "Control-plane audit lane only runs mutates:false commands."}],
        }
    try:
        proc = subprocess.run(cmd, cwd=str(root), text=True, capture_output=True, check=False, timeout=timeout)
    except subprocess.TimeoutExpired as exc:
        return {
            "id": audit_id,
            "status": "block",
            "returncode": None,
            "elapsed_seconds": round(time.time() - started, 3),
            "summary": {"block": 1, "warn": 0, "findings": 1},
            "findings": [{"severity": "block", "code": "audit-timeout", "message": f"Audit timed out after {timeout:g}s.", "details": {"command": cmd, "timeout": timeout, "stdout": exc.stdout, "stderr": exc.stderr}}],
        }
    elapsed = round(time.time() - started, 3)
    try:
        payload = json.loads(proc.stdout)
    except json.JSONDecodeError:
        return {
            "id": audit_id,
            "status": "block",
            "returncode": proc.returncode,
            "elapsed_seconds": elapsed,
            "summary": {"block": 1, "warn": 0, "findings": 1},
            "findings": [{"severity": "block", "code": "audit-json-invalid", "message": "Audit did not emit valid JSON.", "details": {"command": cmd, "stdout_head": proc.stdout[:500], "stderr_head": proc.stderr[:500]}}],
        }
    expected = spec.get("expected_schema")
    findings = list(payload.get("findings", []) or [])
    if expected and payload.get("schema_version") != expected:
        findings.append({"severity": "block", "code": "audit-schema-mismatch", "message": "Audit schema_version does not match manifest expectation.", "details": {"expected": expected, "actual": payload.get("schema_version")}})
    block = sum(1 for f in findings if f.get("severity") == "block")
    warn = sum(1 for f in findings if f.get("severity") == "warn")
    return {
        "id": audit_id,
        "adr": spec.get("adr"),
        "status": "block" if block else "warn" if warn else "pass",
        "returncode": proc.returncode,
        "elapsed_seconds": elapsed,
        "summary": {"block": block, "warn": warn, "findings": len(findings)},
        "findings": findings,
    }


def run_lane(root: Path, manifest: dict[str, Any], lane_name: str) -> dict[str, Any]:
    lanes = manifest.get("lanes", {}) or {}
    audits = manifest.get("audits", {}) or {}
    lane = lanes.get(lane_name)
    if not lane:
        return {
            "schema_version": SCHEMA_VERSION,
            "status": "block",
            "lane": lane_name,
            "summary": {"block": 1, "warn": 0, "findings": 1},
            "audits": [],
            "findings": [{"severity": "block", "code": "unknown-lane", "message": f"Unknown audit lane: {lane_name}"}],
        }
    timeout = float(lane.get("max_seconds", 60))
    results = [run_audit(root, audit_id, audits.get(audit_id, {}), timeout) for audit_id in lane.get("audits", [])]
    block = sum(result["summary"]["block"] for result in results)
    warn = sum(result["summary"]["warn"] for result in results)
    findings = sum(result["summary"]["findings"] for result in results)
    return {
        "schema_version": SCHEMA_VERSION,
        "status": "block" if block else "warn" if warn else "pass",
        "repo": str(root),
        "lane": lane_name,
        "summary": {"block": block, "warn": warn, "findings": findings, "audits": len(results)},
        "audits": results,
        "policy": "Read-only control-plane audit aggregation for ADR-239+ loops.",
    }


def main() -> int:
    parser = argparse.ArgumentParser(description="Run manifest-declared control-plane audits by lane.")
    parser.add_argument("--project-dir", type=Path, default=Path.cwd())
    parser.add_argument("--manifest", type=Path, default=None)
    parser.add_argument("--lane", default="hook-fast", choices=["hook-fast", "hourly", "pre-public"])
    parser.add_argument("--json", action="store_true")
    parser.add_argument("--strict", action="store_true", help="Treat warnings as failures.")
    args = parser.parse_args()
    root = git_root(args.project_dir)
    manifest_path = args.manifest or (root / DEFAULT_MANIFEST)
    report = run_lane(root, load_yaml(manifest_path), args.lane)
    if args.json:
        print(json.dumps(report, indent=2, sort_keys=True))
    else:
        print(f"control-plane audit {args.lane}: {report['status']}")
        for audit in report.get("audits", []):
            print(f"- {audit['id']}: {audit['status']} {audit['summary']}")
    if report["summary"].get("block", 0):
        return 1
    if args.strict and report["summary"].get("warn", 0):
        return 1
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
