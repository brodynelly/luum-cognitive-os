#!/usr/bin/env python3
"""CLI for ADR-201 PromoteFromTelemetry."""
from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
if str(ROOT) not in sys.path:
    sys.path.insert(0, str(ROOT))

from lib.performance_ledger import repo_root  # noqa: E402
from lib.promote_from_telemetry import promote_from_telemetry  # noqa: E402


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description="Promote validated Performance Ledger telemetry into maintainer proposals.")
    parser.add_argument("--project-dir", type=Path, default=repo_root())
    parser.add_argument("--contract", type=Path)
    parser.add_argument("--stream", action="append")
    parser.add_argument("--limit", type=int)
    parser.add_argument("--run-id")
    parser.add_argument("--day-window")
    parser.add_argument("--no-write-ledger", action="store_true")
    parser.add_argument("--dry-run", action="store_true", help="Compatibility flag; PromoteFromTelemetry is propose-only and never applies changes")
    parser.add_argument("--json", action="store_true")
    return parser


def main() -> int:
    args = build_parser().parse_args()
    payload = promote_from_telemetry(
        args.project_dir,
        contract_path=args.contract,
        streams=args.stream,
        limit=args.limit,
        run_id=args.run_id,
        day_window=args.day_window,
        write_ledger=not args.no_write_ledger,
    )
    if args.json:
        print(json.dumps(payload, indent=2, sort_keys=True))
    else:
        print(f"promote-from-telemetry: status={payload['status']} proposals={payload['proposal_count']}")
        if payload["status"] == "blocked_by_signal_quality":
            print("blocked streams: " + ", ".join(payload["blocked_streams"]), file=sys.stderr)
    return 2 if payload["status"] == "blocked_by_signal_quality" else 0


if __name__ == "__main__":
    raise SystemExit(main())
