# =============================================================================
# Cognitive OS — Environment Variables
# =============================================================================
# Copy to .env and fill in values: cp env.example .env

# === LLM Providers ===
# Default Cognitive OS paths do not require Anthropic direct API credentials.
# Add provider keys only for providers you explicitly enable in cognitive-os.yaml.
OPENAI_API_KEY=

# === ADR-049 overflow providers (direct-SDK, no proxy) ===
# Alibaba Qwen Coding Plan Pro ($50/mo — https://www.alibabacloud.com/en/campaign/ai-coding-plan)
# Consumed by lib/qwen_provider.py. ToS: interactive coding tool use only
# (no cron/batch/backend). See ADR-049 for rationale.
ALIBABA_QWEN_API_KEY=
# Workspace-scoped OpenAI-compatible endpoint (from Alibaba Model Studio panel).
# Default (intl generic) used if unset: https://dashscope-intl.aliyuncs.com/compatible-mode/v1
ALIBABA_QWEN_BASE_URL=
# Optional: workspace ID (shown in Alibaba Model Studio panel).
# Not required for API calls but useful for audit trails in metrics.
ALIBABA_QWEN_WORKSPACE_ID=

# === ADR-049 dispatch kill-switches (layered, soft→hard) ===
# These are env flags — typically UNSET. Set only to override cascade behavior.
# See rules/llm-dispatch.md §"Kill-switches" for full semantics.
#
# Cascade-scoped: primary provider fires normally, but cascade does NOT advance
# to fallback providers. Use to debug primary errors or enforce single-provider
# policy without editing --providers flag. Only literal "1" disables.
# COS_DISABLE_LLM_FALLBACK=1
#
# Per-provider: skip Qwen in cascade even if API key is set. Pattern is
# COS_DISABLE_<PROVIDER_UPPER>=1 — extensible to future providers (DeepSeek, MiniMax).
# COS_DISABLE_QWEN=1
#
# Session-scoped Claude-primary override: rewrites --providers to ["claude"] for
# this session, bypassing the default qwen,claude. Use when quality requires
# Claude for all sub-agents or when debugging primary Claude path.
# COS_FORCE_CLAUDE_PRIMARY=1

# === ADR-051 Qwen agent loop — tool-use caps (optional overrides) ===
# Hard-coded defaults in lib/qwen_agent_loop.py: iterations=20, tokens=100000,
# bash_timeout=30s. Env overrides are NOT implemented (adds config surface
# without clear demand). If needed, override per-call via run_agent(...)
# kwargs, not env vars.

# === ADR-062 Multi-provider agent loop — additional providers ===
# Default cascade: qwen → openrouter → gemini → ollama → claude (ADR-062)
# Each provider is skipped automatically if its key is not set / daemon not running.
#
# Tier 2: OpenRouter — aggregates 100+ models, free + paid tiers (openrouter.ai)
# Activate by uncommenting and setting the key. No other config needed.
# OPENROUTER_API_KEY=sk-or-...
#
# Tier 3: Gemini — Google Gemini free tier (aistudio.google.com)
# Free quota is generous for sub-agent use. Paid tier also supported.
# GEMINI_API_KEY=...
#
# Tier 4: Ollama — local models (zero cost, requires daemon at localhost:11434)
# No API key needed. Start daemon: `brew install ollama && ollama serve`
# Pull a model: `ollama pull qwen3:32b` (20GB) or `ollama pull llama3.2:3b` (2GB)
# Enable in cognitive-os.yaml: llm_providers.ollama.enabled: true
# (no env var — is_configured() checks daemon liveness)
#
# Opt-in — paid per-token, not in default cascade:
# OpenAI / ChatGPT (platform.openai.com) — advance only on rate-limit
# OPENAI_API_KEY=sk-...
#
# DeepSeek — strong reasoning, affordable (platform.deepseek.com)
# DEEPSEEK_API_KEY=sk-...
#
# Claude Agent SDK — official Anthropic SDK, requires claude-agent-sdk package
# uv sync --extra claude-sdk   (then set ANTHROPIC_API_KEY below)
# ANTHROPIC_API_KEY=sk-ant-...
#
# Per-provider kill-switches (set to "1" to disable without removing the key):
# COS_DISABLE_OPENROUTER=1
# COS_DISABLE_GEMINI=1
# COS_DISABLE_OLLAMA=1
# COS_DISABLE_OPENAI=1
# COS_DISABLE_DEEPSEEK=1
# COS_DISABLE_CLAUDE_SDK=1

# === Cognee (Knowledge Graph Memory) ===
# ADR-060: opt-in only. Default supported path is pip (cognitive-os.yaml services.cognee.mode: pip).
# Docker reference container is gated: docker compose --profile memory up
# (shared profile with MemU; both start together under --profile memory)
COGNEE_PORT=8100
COGNEE_GRAPH_BACKEND=networkx
COGNEE_VECTOR_STORE=lancedb
COGNEE_LLM_PROVIDER=ollama
COGNEE_LLM_MODEL=llama3.1:8b
COGNEE_LLM_ENDPOINT=http://localhost:11434/v1
COGNEE_LLM_API_KEY=ollama
COGNEE_EMBEDDING_PROVIDER=fastembed
COGNEE_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
COGNEE_EMBEDDING_DIMENSIONS=384

# === NeMo Guardrails (AI Safety Guardrails) ===
# ADR-060: opt-in only. Default supported path is pip (nemoguardrails in-process).
# Docker reference container is gated: docker compose --profile guardrails up
NEMO_GUARDRAILS_PORT=8088
NEMO_LOG_LEVEL=INFO

# === MemU (Local-first memory) ===
# ADR-060: local Docker path ships with a self-contained `memu-pg` backend
# so `docker compose --profile memory up` is zero-cloud. Override MEMU_DB_URL
# to point at an external DB or switch to SQLite. Default supported mode is
# pip (services.memu.mode: pip in cognitive-os.yaml).
MEMU_PG_USER=memu
MEMU_PG_PASS=memu_pass
MEMU_PG_DB=memu
# MEMU_DB_URL=  # leave unset to use the local memu-pg container

# === LiteLLM (LLM Gateway — existing) ===
LITELLM_MASTER_KEY=sk-litellm-master-key

# === Paperclip (Agent Coordination — existing) ===
PAPERCLIP_PG_USER=paperclip
PAPERCLIP_PG_PASS=paperclip_pass
PAPERCLIP_PG_DB=paperclip
BETTER_AUTH_SECRET=cognitive-os-paperclip-local-dev-secret

# === Engram (Persistent Memory — existing) ===
ENGRAM_PORT=7437

# === Notifications ===
# Provider: telegram | slack | webhook | none (default: none)
NOTIFY_PROVIDER=none
# Telegram (required when NOTIFY_PROVIDER=telegram):
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Slack (required when NOTIFY_PROVIDER=slack):
SLACK_WEBHOOK_URL=
# Generic webhook (required when NOTIFY_PROVIDER=webhook):
WEBHOOK_URL=

# === Jupyter (GPU/Compute Sandbox) ===
# ADR-060: opt-in only. Default supported path is pip (jupyter lab).
# Docker reference container is gated: docker compose --profile jupyter up
JUPYTER_PORT=8888
JUPYTER_TOKEN=cognitive-os-dev

# === Singularity Controller (MAPE-K Loop) ===
# Off by default — set to true to enable autonomous operations
SINGULARITY_ENABLED=false
# Polling interval in seconds (default: 86400 = 1 day)
SINGULARITY_INTERVAL=86400
# Daily budget cap in USD (default: 10.00)
SINGULARITY_DAILY_BUDGET=10.00

# === GitHub Webhook Trigger ===
GITHUB_WEBHOOK_SECRET=
GITHUB_TOKEN=
WEBHOOK_PORT=8001

# === Observability Tracing ===
# Phoenix OTel collector endpoint (default: http://localhost:6006/v1/traces).
# Start with: `uv run phoenix serve`. See ADR-058.
# PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006/v1/traces

# === Infrastructure Health Check ===
# Set to true to auto-start missing Docker services on session start (default: false)
INFRA_AUTO_START=false

# === Proof drill provider smoke opt-ins ===
# Optional model pin for explicit Codex host provider proof drills.
# COS_CODEX_EXEC_MODEL=gpt-5.4
