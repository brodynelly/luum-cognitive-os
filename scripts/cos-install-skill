#!/usr/bin/env bash
# SCOPE: os-only
# PURPOSE: Install an extension skill by name into .claude/skills/ routing surface
# Usage: scripts/cos-install-skill <name> [--source <path>] [--dry-run]
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# ---------------------------------------------------------------------------
# Parse arguments
# ---------------------------------------------------------------------------
SKILL_NAME=""
SOURCE_PATH=""
DRY_RUN=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --source)  SOURCE_PATH="$2"; shift 2 ;;
    --dry-run) DRY_RUN=true; shift ;;
    --*)       echo "ERROR: Unknown flag: $1" >&2; exit 1 ;;
    *)
      if [[ -z "$SKILL_NAME" ]]; then
        SKILL_NAME="$1"
      else
        echo "ERROR: Unexpected argument: $1" >&2
        exit 1
      fi
      shift
      ;;
  esac
done

if [[ -z "$SKILL_NAME" ]]; then
  echo "Usage: cos-install-skill <name> [--source <path>] [--dry-run]" >&2
  exit 1
fi

# ---------------------------------------------------------------------------
# Helper: resolve skill source directory
# ---------------------------------------------------------------------------
resolve_source() {
  local name="$1"

  # 1. Explicit --source
  if [[ -n "$SOURCE_PATH" ]]; then
    if [[ ! -d "$SOURCE_PATH" ]]; then
      echo "ERROR: --source path does not exist or is not a directory: $SOURCE_PATH" >&2
      exit 1
    fi
    # Scope check: must be within project root
    local canonical
    canonical="$(cd "$SOURCE_PATH" && pwd)"
    if [[ "$canonical" != "$PROJECT_ROOT"/* ]]; then
      echo "ERROR: source must be within project root (scope violation): $canonical" >&2
      exit 1
    fi
    echo "$canonical"
    return
  fi

  # 2. packages/cos-*/skills/<name>/
  local pkg_match
  pkg_match="$(find "${PROJECT_ROOT}/packages" -maxdepth 3 -type d -name "$name" 2>/dev/null | grep -E "/skills/${name}$" | head -1 || true)"
  if [[ -n "$pkg_match" ]]; then
    echo "$pkg_match"
    return
  fi

  # 3. skills/extensions/<name>/
  if [[ -d "${PROJECT_ROOT}/skills/extensions/${name}" ]]; then
    echo "${PROJECT_ROOT}/skills/extensions/${name}"
    return
  fi

  # 4. skills/<name>/ (present but unlinked)
  if [[ -d "${PROJECT_ROOT}/skills/${name}" ]]; then
    echo "${PROJECT_ROOT}/skills/${name}"
    return
  fi

  echo "ERROR: Cannot find skill '${name}' in any search path." >&2
  echo "  Searched:" >&2
  echo "    packages/cos-*/skills/${name}/" >&2
  echo "    skills/extensions/${name}/" >&2
  echo "    skills/${name}/" >&2
  echo "  Pass --source <path> to specify location explicitly." >&2
  exit 1
}

# ---------------------------------------------------------------------------
# Helper: validate SKILL.md frontmatter (minimal)
# ---------------------------------------------------------------------------
validate_skill() {
  local skill_dir="$1"
  local skill_md="${skill_dir}/SKILL.md"

  if [[ ! -f "$skill_md" ]]; then
    echo "ERROR: SKILL.md not found at: $skill_md" >&2
    exit 1
  fi

  # Check required frontmatter fields
  local missing=()
  grep -q "^name:" "$skill_md"        || missing+=("name")
  grep -q "^description:" "$skill_md" || missing+=("description")
  grep -q "^version:" "$skill_md"     || missing+=("version")

  if [[ ${#missing[@]} -gt 0 ]]; then
    echo "ERROR: SKILL.md at ${skill_md} is missing required frontmatter fields: ${missing[*]}" >&2
    exit 1
  fi

  # Check name matches argument
  local declared_name
  declared_name="$(grep "^name:" "$skill_md" | head -1 | sed 's/^name:[[:space:]]*//' | tr -d "'\"")"
  if [[ "$declared_name" != "$SKILL_NAME" ]]; then
    echo "WARNING: frontmatter name='${declared_name}' does not match argument '${SKILL_NAME}'" >&2
  fi
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------
RESOLVED_SOURCE="$(resolve_source "$SKILL_NAME")"
SYMLINK_TARGET="${PROJECT_ROOT}/.claude/skills/${SKILL_NAME}"

echo "install-skill: resolved source: ${RESOLVED_SOURCE}"

# Validate SKILL.md
validate_skill "$RESOLVED_SOURCE"

# Check for collision
if [[ -L "$SYMLINK_TARGET" ]]; then
  existing="$(readlink -f "$SYMLINK_TARGET" 2>/dev/null || true)"
  echo "ERROR: Skill '${SKILL_NAME}' is already installed at .claude/skills/${SKILL_NAME}" >&2
  echo "  Current target: ${existing}" >&2
  echo "  Use '/add-skill' to author a replacement, or remove the existing symlink first." >&2
  exit 1
fi
if [[ -e "$SYMLINK_TARGET" ]]; then
  echo "ERROR: Path .claude/skills/${SKILL_NAME} exists and is not a symlink — refusing to overwrite." >&2
  exit 1
fi

# Compute relative symlink path (following convention: ../../../skills/<name>)
RELATIVE_TARGET="$(python3 -c "
import os
link = '${SYMLINK_TARGET}'
target = '${RESOLVED_SOURCE}'
print(os.path.relpath(target, os.path.dirname(link)))
")"

echo "install-skill: symlink: .claude/skills/${SKILL_NAME} -> ${RELATIVE_TARGET}"

if [[ "$DRY_RUN" == "true" ]]; then
  echo "[dry-run] Would create: .claude/skills/${SKILL_NAME} -> ${RELATIVE_TARGET}"
  echo "[dry-run] Would NOT modify cognitive-os.yaml (no package source detected)"
  echo "[dry-run] Done. No files written."
  exit 0
fi

# Create the symlink
ln -s "$RELATIVE_TARGET" "$SYMLINK_TARGET"
echo "install-skill: created .claude/skills/${SKILL_NAME}"

# Register in cognitive-os.yaml if coming from a packages/cos-* pack
if [[ "$RESOLVED_SOURCE" == "${PROJECT_ROOT}/packages/"* ]]; then
  PACK_NAME="$(echo "$RESOLVED_SOURCE" | sed "s|${PROJECT_ROOT}/packages/||" | cut -d'/' -f1)"
  COSYAML="${PROJECT_ROOT}/cognitive-os.yaml"

  python3 - "$COSYAML" "$SKILL_NAME" "$PACK_NAME" << 'PYEOF'
import sys, pathlib, re

cosyaml_path = pathlib.Path(sys.argv[1])
skill_name = sys.argv[2]
pack_name = sys.argv[3]

content = cosyaml_path.read_text()

# Build entry line
entry = f"  - name: {skill_name}\n    pack: {pack_name}\n"

if "extensions:" in content:
    # Append under existing extensions key
    content = re.sub(r"(extensions:\n)", r"\1" + entry, content, count=1)
else:
    # Append extensions section at end of file
    content = content.rstrip("\n") + "\n\nextensions:\n" + entry + "\n"

cosyaml_path.write_text(content)
print(f"install-skill: registered in cognitive-os.yaml extensions: {skill_name} (pack: {pack_name})")
PYEOF
fi

echo "install-skill: SUCCESS — /${SKILL_NAME} is now active"
echo "  Slash command: /${SKILL_NAME}"
