#!/usr/bin/env python3
# SCOPE: os-only
"""Report observable primitive self-use from joined COS trace streams."""
from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
if str(ROOT) not in sys.path:
    sys.path.insert(0, str(ROOT))

from lib.trace_joiner import build_run_trace


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--project-dir", type=Path, default=ROOT)
    parser.add_argument("--run-id")
    parser.add_argument("--session-id")
    parser.add_argument("--limit", type=int)
    parser.add_argument("--no-write", action="store_true")
    parser.add_argument("--json", action="store_true")
    args = parser.parse_args()
    payload = build_run_trace(
        args.project_dir,
        run_id=args.run_id,
        session_id=args.session_id,
        limit_per_stream=args.limit,
        write=not args.no_write,
    )
    report = {
        "schema_version": "cos-observe-primitives.v1",
        "run_id": payload["run_id"],
        "session_id": payload.get("session_id"),
        "event_count": payload["event_count"],
        "streams": payload["streams"],
        "observable_self_use": payload["observable_self_use"],
        "trace_status": payload["final_status"],
    }
    if args.json:
        print(json.dumps(report, indent=2, sort_keys=True))
    else:
        summary = report["observable_self_use"]
        print(
            "primitive self-use: "
            f"itinerary={summary['codebase_itinerary_events']} "
            f"interventions={summary['primitive_intervention_events']} "
            f"status={report['trace_status']}"
        )
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
