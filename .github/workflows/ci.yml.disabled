name: CI

on:
  push:
    branches: [main]
  pull_request:
    branches: [main]

permissions:
  contents: read

jobs:
  python-core:
    name: Python Core Validation
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: '3.11'

      - name: Install Python test dependencies
        run: |
          python -m pip install --upgrade pip
          pip install pytest pyyaml

      - name: Run representative Python core tests
        run: |
          python3 -m pytest \
            tests/contracts/test_kernel_contract.py \
            tests/contracts/test_product_zones.py \
            tests/contracts/test_killswitch.py \
            tests/unit/test_execution_profile.py \
            tests/unit/test_compatibility_layer.py \
            tests/unit/test_outcome_metrics.py \
            tests/unit/test_model_router.py \
            tests/unit/test_config_loader.py \
            tests/unit/test_cross_platform_discipline.py \
            tests/behavior/test_self_install.py \
            -q

  go-core:
    name: Go Core Validation
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Set up Go
        uses: actions/setup-go@v5
        with:
          go-version-file: go.mod

      - name: Run Go kernel and provider tests
        run: go test ./internal/provider/... ./internal/validator/... ./pkg/hook/... -count=1

  test-runner-defaults:
    name: Test Runner Default Policy
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: '3.11'

      - name: Set up Go
        uses: actions/setup-go@v5
        with:
          go-version-file: cmd/cos-test/go.mod

      - name: Install Python test-runner dependencies
        run: |
          python -m pip install --upgrade pip
          pip install pytest pytest-xdist pytest-timeout pyyaml

      - name: Validate cos-test defaults
        run: |
          cd cmd/cos-test
          go test ./... -count=1
          go run . broad --no-docker --dry-run

  docs-integrity:
    name: Documentation Integrity
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Validate product-facing markdown links and commands
        run: |
          python3 -c "
          import re, sys
          from pathlib import Path

          docs = [Path('README.md'), Path('CONTRIBUTING.md'), Path('docs/README.md')]
          errors = 0

          def normalize(target: str) -> str:
              target = target.strip().strip('<>')
              target = target.split('#', 1)[0]
              target = target.split('?', 1)[0]
              return target

          for doc in docs:
              text = doc.read_text(encoding='utf-8')
              for raw_target in re.findall(r'(?<!!)\[[^\]]+\]\(([^)]+)\)', text):
                  target = normalize(raw_target)
                  if not target or target.startswith(('http://', 'https://', 'mailto:', '#')):
                      continue
                  resolved = (doc.parent / target).resolve()
                  if not resolved.exists():
                      print(f'FAIL: {doc} -> missing target {target}')
                      errors += 1

          contrib = Path('CONTRIBUTING.md').read_text(encoding='utf-8')
          if 'bash tests/run-all-tests.sh' in contrib:
              print('FAIL: CONTRIBUTING.md still references tests/run-all-tests.sh')
              errors += 1

          sys.exit(1 if errors else 0)
          "

  config-validation:
    name: Config Validation
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: '3.11'

      - name: Install validation dependencies
        run: |
          python -m pip install --upgrade pip
          pip install pyyaml

      - name: Validate YAML configs
        run: |
          python3 -c "
          import yaml, sys, glob
          errors = 0
          for f in glob.glob('**/*.yaml', recursive=True) + glob.glob('**/*.yml', recursive=True):
              try:
                  with open(f, encoding='utf-8') as fh:
                      yaml.safe_load(fh)
              except Exception as e:
                  print(f'FAIL: {f}: {e}')
                  errors += 1
          sys.exit(1 if errors else 0)
          "

      - name: Validate Docker Compose config
        run: docker compose -f docker-compose.cognitive-os.yml config --quiet

  security:
    name: Security Checks
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Check for secrets in codebase
        run: |
          if [ -f hooks/secret-detector.sh ]; then
            CLAUDE_PROJECT_DIR="$PWD" bash hooks/secret-detector.sh || true
          fi

      - name: Verify .gitignore covers sensitive files
        run: |
          MISSING=0
          for pattern in ".env" ".env.local" "*.pem" "*.key"; do
            if ! grep -q "$pattern" .gitignore 2>/dev/null; then
              echo "WARNING: $pattern not in .gitignore"
              MISSING=1
            fi
          done
          exit $MISSING
