#!/usr/bin/env bash
# SCOPE: os-only
# cos-pi-agent — pi harness gateway for `cos run-task` (ADR-336)
#
# Runs the pi coding agent (@earendil-works/pi-coding-agent) headlessly as the
# `execution.command` of a `cos run-task` payload. `cos run-task` creates the
# isolated worktree, injects COS_TASK_* env vars, runs THIS script as the agent,
# then runs the acceptance criteria and writes the trust-report. This script is
# the single agent-invocation choke point ("gateway") — it never reasons; it
# just builds and execs the pi command.
#
# Usage:
#   cos-pi-agent [--role <role>] [--task <text>] [--dry-run]
#
# Inputs (env, injected by `cos run-task`):
#   COS_TASK_DESCRIPTION   task body — primary prompt source
#   COS_TASK_TITLE         short title (prepended to the prompt when present)
# Config (env or flags):
#   COS_PI_ROLE / --role        pi persona from <agents-dir>/<role>.md (default: builder)
#   COS_PI_AGENTS_DIR           dir holding <role>.md
#                               (default: $HOME/.pi/agents, then ./.pi/agents)
#   COS_PI_PROVIDER             pi --provider (default: pi's own default)
#   COS_PI_MODEL                pi --model    (default: pi's own default)
#   COS_PI_DRYRUN=1 / --dry-run print the resolved pi command and exit 0
#                               (wiring/verification without invoking pi)
set -euo pipefail

ROLE="${COS_PI_ROLE:-builder}"
TASK="${COS_TASK_DESCRIPTION:-}"
TITLE="${COS_TASK_TITLE:-}"
DRYRUN="${COS_PI_DRYRUN:-0}"

while [ "$#" -gt 0 ]; do
  case "$1" in
    --role) [ "$#" -ge 2 ] || { echo "cos-pi-agent: --role requires a value" >&2; exit 2; }; ROLE="$2"; shift ;;
    --role=*) ROLE="${1#--role=}" ;;
    --task) [ "$#" -ge 2 ] || { echo "cos-pi-agent: --task requires a value" >&2; exit 2; }; TASK="$2"; shift ;;
    --task=*) TASK="${1#--task=}" ;;
    --dry-run) DRYRUN=1 ;;
    -h|--help) sed -n '2,30p' "$0"; exit 0 ;;
    *) echo "cos-pi-agent: unknown arg: $1" >&2; exit 2 ;;
  esac
  shift
done

if [ -n "$TITLE" ] && [ -n "$TASK" ]; then
  TASK="${TITLE}

${TASK}"
fi

if [ -z "$TASK" ]; then
  echo "cos-pi-agent: no task (set COS_TASK_DESCRIPTION or pass --task)" >&2
  exit 2
fi

# Resolve the pi persona file (optional — pi runs without it too).
AGENTS_DIR="${COS_PI_AGENTS_DIR:-}"
if [ -z "$AGENTS_DIR" ]; then
  if [ -d "$HOME/.pi/agents" ]; then
    AGENTS_DIR="$HOME/.pi/agents"
  elif [ -d "./.pi/agents" ]; then
    AGENTS_DIR="./.pi/agents"
  fi
fi
ROLE_FILE=""
if [ -n "$AGENTS_DIR" ] && [ -f "$AGENTS_DIR/$ROLE.md" ]; then
  ROLE_FILE="$AGENTS_DIR/$ROLE.md"
fi

# Build the pi argv. pi runs in $PWD, which is the run-task isolated worktree.
set -- pi -p --mode json --no-session
[ -n "$ROLE_FILE" ] && set -- "$@" --append-system-prompt "$ROLE_FILE"
[ -n "${COS_PI_PROVIDER:-}" ] && set -- "$@" --provider "$COS_PI_PROVIDER"
[ -n "${COS_PI_MODEL:-}" ] && set -- "$@" --model "$COS_PI_MODEL"
set -- "$@" "$TASK"

if [ "$DRYRUN" = "1" ]; then
  printf 'DRYRUN cos-pi-agent role=%s role_file=%s\n' "$ROLE" "${ROLE_FILE:-<none>}"
  printf '%q ' "$@"
  printf '\n'
  exit 0
fi

if ! command -v pi >/dev/null 2>&1; then
  echo "cos-pi-agent: 'pi' not found on PATH (install @earendil-works/pi-coding-agent)" >&2
  exit 127
fi

exec "$@"
