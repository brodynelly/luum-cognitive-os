#!/usr/bin/env bash
# SCOPE: os-only
# ROLE: observability
# CANONICAL: scripts/cos-coverage
# @on-demand: Print Agent Capability Coverage (ACC) metrics.
#
# Usage:
#   cos-coverage                 # human summary
#   cos-coverage --json          # machine-readable JSON
#   cos-coverage --brief         # one-line statusline output
#   cos-coverage --refresh       # force cache refresh
#   cos-coverage --project-dir P # override project root

set -uo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$("$SCRIPT_DIR/cos-root" project)"

exec python3 "${SCRIPT_DIR}/cos_coverage.py" "$@"
