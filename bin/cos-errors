#!/usr/bin/env python3
# cos-errors — COS error taxonomy CLI (ADR-080 Tier 2 #6)
#
# Usage:
#   cos-errors classify [<jsonl-path>]          Classify all records; print JSON
#   cos-errors insights [--window=24h]           Print insight report (text)
#   cos-errors insights --json [--window=24h]   Print insight report (JSON)
#   cos-errors --help
#
# Default JSONL path: .cognitive-os/metrics/error-learning.jsonl
# (resolved relative to CLAUDE_PROJECT_DIR or cwd)
#
# Environment:
#   CLAUDE_PROJECT_DIR          Project root override
#   COS_ERROR_DEEP_CLASSIFY=1   Enable LLM-based deep classification
import argparse
import json
import re
import sys
from pathlib import Path


def _add_lib_to_path():
    """Ensure lib/ is importable when running directly from bin/."""
    script_dir = Path(__file__).resolve().parent
    repo_root = script_dir.parent
    if str(repo_root) not in sys.path:
        sys.path.insert(0, str(repo_root))


_add_lib_to_path()

from lib.error_classifier import classify_jsonl, default_errors_path  # noqa: E402
from lib.error_insights import summarize  # noqa: E402


def _parse_window(value: str) -> int:
    """Parse a window string like '24h', '2h', '48' into hours (int)."""
    value = value.strip()
    m = re.match(r"^(\d+)h?$", value, re.IGNORECASE)
    if not m:
        raise argparse.ArgumentTypeError(
            f"Invalid window '{value}'. Use an integer (hours) or '<N>h', e.g. '24h'."
        )
    return int(m.group(1))


def cmd_classify(args) -> int:
    path = Path(args.jsonl) if args.jsonl else default_errors_path()
    if not path.exists():
        print(f"cos-errors: file not found: {path}", file=sys.stderr)
        return 1

    classified = classify_jsonl(path)
    output = []
    for ce in classified:
        output.append({
            "category": ce.category.value,
            "severity": ce.classification.severity.value,
            "transient": ce.classification.transient.value,
            "suggested_action": ce.classification.suggested_action,
            **{k: v for k, v in ce.record.items()
               if k not in ("category", "severity", "transient", "suggested_action")},
        })
    print(json.dumps(output, indent=2, default=str))
    return 0


def cmd_insights(args) -> int:
    path = Path(args.jsonl) if getattr(args, "jsonl", None) else default_errors_path()
    window = _parse_window(args.window) if isinstance(args.window, str) else args.window

    if not path.exists():
        print(f"cos-errors: file not found: {path}", file=sys.stderr)
        return 1

    classified = classify_jsonl(path)
    report = summarize(classified, window_hours=window)

    if getattr(args, "json", False):
        print(json.dumps(report.as_dict(), indent=2, default=str))
    else:
        print(report.format_text())
    return 0


def main() -> int:
    parser = argparse.ArgumentParser(
        prog="cos-errors",
        description="COS error taxonomy CLI — classify and analyze error-learning.jsonl",
    )
    sub = parser.add_subparsers(dest="command")

    # classify
    p_classify = sub.add_parser("classify", help="Classify all records in a JSONL file")
    p_classify.add_argument(
        "jsonl", nargs="?", default=None,
        help="Path to error-learning.jsonl (default: .cognitive-os/metrics/error-learning.jsonl)",
    )

    # insights
    p_insights = sub.add_parser("insights", help="Generate insight report from classified errors")
    p_insights.add_argument(
        "--window", default="24h",
        help="Analysis window: integer hours or '<N>h' (default: 24h)",
    )
    p_insights.add_argument(
        "--json", action="store_true", default=False,
        help="Output JSON instead of human-readable text",
    )
    p_insights.add_argument(
        "jsonl", nargs="?", default=None,
        help="Path to error-learning.jsonl (default: .cognitive-os/metrics/error-learning.jsonl)",
    )

    args = parser.parse_args()

    if args.command == "classify":
        return cmd_classify(args)
    if args.command == "insights":
        return cmd_insights(args)

    parser.print_help()
    return 0


if __name__ == "__main__":
    sys.exit(main())
