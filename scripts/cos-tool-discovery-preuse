#!/usr/bin/env python3
"""CLI for Tool Discovery Pre-Use Gate."""
from __future__ import annotations

import argparse
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
if str(ROOT) not in sys.path:
    sys.path.insert(0, str(ROOT))

from lib.tool_discovery_preuse import dumps_json, evaluate_command, format_human  # noqa: E402


def main() -> int:
    parser = argparse.ArgumentParser(description="Check whether a Bash command bypasses an existing COS primitive.")
    parser.add_argument("--project-dir", type=Path, default=ROOT)
    parser.add_argument("--command", required=True)
    parser.add_argument("--json", action="store_true")
    args = parser.parse_args()
    report = evaluate_command(args.command, args.project_dir)
    if args.json:
        print(dumps_json(report))
    else:
        print(format_human(report), file=sys.stderr if report["status"] == "block" else sys.stdout)
    return 2 if report["status"] == "block" else 0


if __name__ == "__main__":
    raise SystemExit(main())
