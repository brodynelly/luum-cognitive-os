#!/usr/bin/env python3
# SCOPE: both
"""ADR-235 detached agent daemon CLI (opt-in, local-first)."""
from __future__ import annotations

import argparse
import json
import sys
from dataclasses import asdict, is_dataclass
from pathlib import Path
from typing import Any

ROOT = Path(__file__).resolve().parent.parent
if str(ROOT) not in sys.path:
    sys.path.insert(0, str(ROOT))

from lib.agent_daemon import AgentDaemon, AgentDaemonError  # noqa: E402
from lib.agent_lifecycle import AgentLifecycleError, prepare_agent_worktree  # noqa: E402
from lib.agent_team import AgentTeam  # noqa: E402


def _default(value: Any) -> Any:
    if is_dataclass(value):
        return asdict(value)
    if isinstance(value, Path):
        return str(value)
    raise TypeError(type(value).__name__)


def emit(payload: dict[str, Any], *, json_output: bool) -> None:
    if json_output:
        print(json.dumps(payload, sort_keys=True, default=_default))
        return
    print(f"cos agent daemon: {payload.get('status', 'ok')}")
    if payload.get("task"):
        task = payload["task"]
        print(f"task: {task.get('task_id')} {task.get('status')} {task.get('tmux_session')}")


def daemon(args: argparse.Namespace) -> AgentDaemon:
    return AgentDaemon(project_dir=args.project_dir, root_dir=args.root_dir)


def cmd_enqueue(args: argparse.Namespace) -> int:
    worktree_path = args.worktree_path
    if args.prepare_worktree:
        if not args.task_id:
            raise AgentDaemonError("--prepare-worktree requires --task-id")
        record = prepare_agent_worktree(
            args.project_dir,
            task_id=args.task_id,
            session_id=args.session_id or "detached",
            worktree_root=args.worktree_root,
            branch_prefix=args.branch_prefix,
        )
        worktree_path = record.worktree_path
    task = daemon(args).enqueue(
        command=args.command,
        task_id=args.task_id,
        session_id=args.session_id,
        worktree_path=worktree_path,
        team_name=args.team,
        max_runtime_seconds=args.max_runtime_seconds,
        estimated_cost_usd=args.estimated_cost_usd,
        budget_cap_usd=args.budget_cap_usd,
    )
    emit({"status": "queued", "task": task.to_dict()}, json_output=args.json)
    return 0


def cmd_list(args: argparse.Namespace) -> int:
    tasks = [task.to_dict() for task in daemon(args).list_tasks()]
    emit({"status": "ok", "tasks": tasks}, json_output=args.json)
    return 0


def cmd_run_once(args: argparse.Namespace) -> int:
    task = daemon(args).launch_next(tmux_bin=args.tmux_bin, dry_run=args.dry_run)
    emit({"status": "no_queued_task" if task is None else "launched", "task": task.to_dict() if task else None}, json_output=args.json)
    return 0


def cmd_reap(args: argparse.Namespace) -> int:
    d = daemon(args)
    completed = [task.to_dict() for task in d.reap_completed()]
    stale = [task.to_dict() for task in d.reap_stale(stale_heartbeat_seconds=args.stale_heartbeat_seconds)]
    emit({"status": "ok", "completed": completed, "stale_failed": stale}, json_output=args.json)
    return 0


def cmd_service_plan(args: argparse.Namespace) -> int:
    d = daemon(args)
    unit = d.launchd_plist(python_bin=args.python_bin) if args.kind == "launchd" else d.systemd_unit(python_bin=args.python_bin)
    payload = {"status": "ok", "kind": args.kind, "content": unit}
    if args.json:
        print(json.dumps(payload, sort_keys=True))
    else:
        print(unit, end="")
    return 0



def cmd_install_service(args: argparse.Namespace) -> int:
    path = daemon(args).install_service(kind=args.kind, target_dir=args.target_dir, python_bin=args.python_bin)
    emit({"status": "installed", "kind": args.kind, "path": str(path)}, json_output=args.json)
    return 0


def cmd_kill(args: argparse.Namespace) -> int:
    task = daemon(args).kill_task(args.task_id, tmux_bin=args.tmux_bin, reason=args.reason)
    emit({"status": "killed", "task": task.to_dict()}, json_output=args.json)
    return 0

def cmd_enqueue_team_next(args: argparse.Namespace) -> int:
    team = AgentTeam(args.team, project_dir=args.project_dir)
    task = team.claim_next(session_id=args.session_id)
    if task is None:
        emit({"status": "no_claimable_team_task", "task": None}, json_output=args.json)
        return 0
    command = args.command_template.format(task_id=task.task_id, title=task.title)
    queued = daemon(args).enqueue(
        command=command,
        task_id=task.task_id,
        session_id=args.session_id,
        worktree_path=args.worktree_path,
        team_name=args.team,
        max_runtime_seconds=args.max_runtime_seconds,
        estimated_cost_usd=args.estimated_cost_usd,
        budget_cap_usd=args.budget_cap_usd,
    )
    emit({"status": "queued_team_task", "team_task": asdict(task), "task": queued.to_dict()}, json_output=args.json)
    return 0


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--project-dir", required=True)
    parser.add_argument("--root-dir")
    parser.add_argument("--json", action="store_true")
    sub = parser.add_subparsers(dest="command_name", required=True)

    enqueue = sub.add_parser("enqueue", help="Queue a detached agent task")
    enqueue.add_argument("--command", required=True)
    enqueue.add_argument("--task-id")
    enqueue.add_argument("--session-id")
    enqueue.add_argument("--team")
    enqueue.add_argument("--worktree-path")
    enqueue.add_argument("--prepare-worktree", action="store_true")
    enqueue.add_argument("--worktree-root")
    enqueue.add_argument("--branch-prefix", default="codex/task", help="Branch prefix for --prepare-worktree; default aligns ADR-225")
    enqueue.add_argument("--max-runtime-seconds", type=int, default=3600)
    enqueue.add_argument("--estimated-cost-usd", type=float, default=0.0)
    enqueue.add_argument("--budget-cap-usd", type=float, default=5.0)
    enqueue.set_defaults(func=cmd_enqueue)

    enqueue_team = sub.add_parser("enqueue-team-next", help="Claim and queue the next ADR-233 team task")
    enqueue_team.add_argument("--team", required=True)
    enqueue_team.add_argument("--session-id", required=True)
    enqueue_team.add_argument("--command-template", required=True, help="Format string with {task_id} and {title}")
    enqueue_team.add_argument("--worktree-path")
    enqueue_team.add_argument("--max-runtime-seconds", type=int, default=3600)
    enqueue_team.add_argument("--estimated-cost-usd", type=float, default=0.0)
    enqueue_team.add_argument("--budget-cap-usd", type=float, default=5.0)
    enqueue_team.set_defaults(func=cmd_enqueue_team_next)

    listed = sub.add_parser("list", help="List detached agent tasks")
    listed.set_defaults(func=cmd_list)

    run_once = sub.add_parser("run-once", help="Launch one queued task in tmux")
    run_once.add_argument("--tmux-bin")
    run_once.add_argument("--dry-run", action="store_true")
    run_once.set_defaults(func=cmd_run_once)

    reap = sub.add_parser("reap", help="Mark running tasks completed when done.json exists and fail stale tasks")
    reap.add_argument("--stale-heartbeat-seconds", type=int, default=300)
    reap.set_defaults(func=cmd_reap)

    service_plan = sub.add_parser("service-plan", help="Print opt-in launchd/systemd service definition")
    service_plan.add_argument("--kind", choices=["launchd", "systemd"], required=True)
    service_plan.add_argument("--python-bin", default="python3")
    service_plan.set_defaults(func=cmd_service_plan)

    install_service = sub.add_parser("install-service", help="Install opt-in launchd/systemd service file without activating it")
    install_service.add_argument("--kind", choices=["launchd", "systemd"], required=True)
    install_service.add_argument("--python-bin", default="python3")
    install_service.add_argument("--target-dir")
    install_service.set_defaults(func=cmd_install_service)

    kill = sub.add_parser("kill", help="Kill a detached task tmux session and mark it failed")
    kill.add_argument("--task-id", required=True)
    kill.add_argument("--tmux-bin")
    kill.add_argument("--reason", default="operator_killed")
    kill.set_defaults(func=cmd_kill)

    return parser


def main(argv: list[str] | None = None) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)
    try:
        return int(args.func(args))
    except (AgentDaemonError, AgentLifecycleError) as exc:
        payload = {"status": "error", "error": str(exc), "error_type": type(exc).__name__}
        if getattr(args, "json", False):
            print(json.dumps(payload, sort_keys=True), file=sys.stderr)
        else:
            print(f"cos-agent-daemon: ERROR — {exc}", file=sys.stderr)
        return 2


if __name__ == "__main__":
    raise SystemExit(main())
