#!/usr/bin/env python3
from __future__ import annotations

import argparse
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
if str(ROOT) not in sys.path:
    sys.path.insert(0, str(ROOT))

from lib.external_tool_intelligence import research_check, write_json


def main() -> int:
    parser = argparse.ArgumentParser(description="Validate an external-tool research packet before adoption.")
    parser.add_argument("candidate", help="YAML/JSON research packet")
    parser.add_argument("--json", action="store_true", help="Emit JSON (default).")
    args = parser.parse_args()
    payload = research_check(Path(args.candidate))
    print(write_json(payload), end="")
    return 1 if payload["status"] == "block" else 0


if __name__ == "__main__":
    raise SystemExit(main())
