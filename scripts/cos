#!/usr/bin/env bash
# SCOPE: project
# cos — minimal subcommand dispatcher for Cognitive OS
#
# Routes:
#   cos status [flags]                 -> scripts/cos-status.sh
#   cos coverage [flags]               -> scripts/cos-coverage
#   cos tui --snapshot|--operate ACTION -> scripts/cos-tui
#   cos primitive harness-coverage     -> scripts/primitive_harness_coverage.py
#   cos init-check                     -> scripts/cos-doctor-harness.sh --init-check
#   cos doctor harness [flags]         -> scripts/cos-doctor-harness.sh
#   cos measure harness-profiles       -> scripts/measure_harness_profiles.py
#   cos sprint ...                     -> scripts/cos_sprint.py
#   cos subagent preflight             -> scripts/subagent_launch_preflight.py
#   cos agent worktree prepare          -> scripts/cos-agent-worktree-prepare
#   cos agent daemon ...                -> scripts/cos-agent-daemon
#   cos private-content audit          -> scripts/private_content_audit.py
#   cos private-content check-projection -> scripts/private_content_audit.py --check-projection
#   cos dependency adoption-gate        -> scripts/cos-dependency-adoption-gate
#   cos reward-signal audit            -> scripts/cos-reward-signal-audit
#   cos license audit                   -> scripts/cos-cross-stack-license-audit
#   cos secret audit                    -> scripts/cos-cross-stack-secret-audit
#   cos publication safety              -> scripts/cos-publication-safety
#   cos adoption audit                  -> scripts/cos-cross-stack-adoption-truth
#   cos history sanitize                -> scripts/cos-history-sanitization
#   cos tool-discovery preuse        -> scripts/cos-tool-discovery-preuse
#   cos mcp registration-plan         -> scripts/cos-mcp-registration-plan
#   cos team ...                    -> scripts/cos-team
#   cos performance-ledger compile     -> scripts/cos-performance-ledger
#   cos observe run                    -> scripts/cos-run-trace
#   cos observe primitives             -> scripts/cos-observe-primitives
#   cos adapters ...                   -> scripts/cos-adapters
#   cos rollback                        -> scripts/cos-rollback
#   cos service readiness              -> scripts/cos-service-readiness-gate
#   cos promote-from-telemetry          -> scripts/cos-promote-from-telemetry
#   cos maintainer once                 -> scripts/cos-maintainer-agent --once
#   cos adr resolve N                   -> scripts/cos-adr-resolve
#   cos profile explain                 -> scripts/cos-profile-explain
#   cos work ownership                  -> scripts/cos_work_inventory.py --paths
#   cos worktree audit                   -> scripts/cos-worktree-audit
#   cos state retention [flags]         -> scripts/state_retention_audit.py
#   cos stash cleanup [flags]           -> scripts/state_retention_audit.py --surface auto-pre-agent-stashes --reap
#   cos *                              -> bin/cognitive-os.sh (init, doctor, list, install, ...)
#
# This keeps the `cos` UX short (`cos status`, `cos init`) while leaving the
# full CLI in bin/cognitive-os.sh unchanged.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$("$SCRIPT_DIR/cos-root" project)"

SUBCMD="${1:-help}"

case "$SUBCMD" in
  status)
    shift
    exec bash "$SCRIPT_DIR/cos-status.sh" "$@"
    ;;
  coverage)
    shift
    exec bash "$SCRIPT_DIR/cos-coverage" "$@"
    ;;
  tui)
    shift
    exec python3 "$SCRIPT_DIR/cos-tui" --project-dir "$PROJECT_ROOT" "$@"
    ;;
  primitive)
    if [ "${2:-}" = "harness-coverage" ] || [ "${2:-}" = "surface-coverage" ]; then
      shift 2
      exec python3 "$SCRIPT_DIR/primitive_harness_coverage.py" --project-dir "$PROJECT_ROOT" "$@"
    fi
    echo "cos: unknown primitive subcommand '${2:-}'. Try: cos primitive {harness-coverage|surface-coverage}" >&2
    exit 1
    ;;
  init-check)
    shift
    exec bash "$SCRIPT_DIR/cos-doctor-harness.sh" --init-check "$@"
    ;;
  doctor)
    if [ "${2:-}" = "harness" ]; then
      shift 2
      exec bash "$SCRIPT_DIR/cos-doctor-harness.sh" "$@"
    fi
    FULL_CLI="$PROJECT_ROOT/bin/cognitive-os.sh"
    if [ ! -x "$FULL_CLI" ]; then
      echo "cos: bin/cognitive-os.sh not found or not executable at $FULL_CLI" >&2
      exit 1
    fi
    exec bash "$FULL_CLI" "$@"
    ;;
  measure)
    if [ "${2:-}" = "harness-profiles" ]; then
      shift 2
      exec python3 "$SCRIPT_DIR/measure_harness_profiles.py" "$@"
    fi
    echo "cos: unknown measure target '${2:-}'. Try: cos measure harness-profiles" >&2
    exit 1
    ;;
  land)
    shift
    exec bash "$SCRIPT_DIR/merge-to-main.sh" "$@"
    ;;
  merge)
    if [ "${2:-}" = "queue" ]; then
      shift 2
      exec bash "$SCRIPT_DIR/cos-merge-queue.sh" "$@"
    fi
    echo "cos: unknown merge subcommand '${2:-}'. Try: cos merge queue {enqueue|peek|status|list|dequeue}" >&2
    exit 1
    ;;
  profile)
    if [ "${2:-}" = "explain" ]; then
      shift 2
      exec "$SCRIPT_DIR/cos-profile-explain" --project-dir "$PROJECT_ROOT" "$@"
    fi
    echo "cos: unknown profile subcommand '${2:-}'. Try: cos profile explain [--json]" >&2
    exit 1
    ;;
  governance)
    if [ "${2:-}" = "roi" ]; then
      shift 2
      exec bash "$SCRIPT_DIR/cos-governance-roi" "$@"
    fi
    if [ "${2:-}" = "catch" ]; then
      case "${3:-}" in
        log)
          shift 3
          exec bash "$SCRIPT_DIR/cos-governance-roi" catch-log "$@"
          ;;
        pending)
          shift 3
          exec bash "$SCRIPT_DIR/cos-governance-roi" catch-pending "$@"
          ;;
        *)
          echo "cos: unknown governance catch subcommand '${3:-}'. Try: cos governance catch {log|pending}" >&2
          exit 1
          ;;
      esac
    fi
    if [ "${2:-}" = "policy" ]; then
      shift 2
      exec bash "$SCRIPT_DIR/cos-governance-roi" policy "$@"
    fi
    if [ "${2:-}" = "readiness" ]; then
      shift 2
      exec bash "$SCRIPT_DIR/cos-architecture-readiness" "$@"
    fi
    echo "cos: unknown governance subcommand '${2:-}'. Try: cos governance {roi|catch|policy|readiness}" >&2
    exit 1
    ;;
  validation)
    # ADR-108: validation capsule diagnostic + recovery
    case "${2:-status}" in
      status)
        shift 2 2>/dev/null || shift
        exec bash "$SCRIPT_DIR/cos-validation-status.sh" "$@"
        ;;
      break)
        shift 2
        exec bash "$SCRIPT_DIR/cos-validation-break.sh" "$@"
        ;;
      *)
        echo "cos: unknown validation subcommand '${2:-}'. Try: cos validation {status|break}" >&2
        exit 1
        ;;
    esac
    exit 0
    ;;
  sprint)
    shift
    exec python3 "$SCRIPT_DIR/cos_sprint.py" "$@"
    ;;
  agent)
    if [ "${2:-}" = "worktree" ] && [ "${3:-}" = "prepare" ]; then
      shift 3
      exec "$SCRIPT_DIR/cos-agent-worktree-prepare" --project-dir "$PROJECT_ROOT" "$@"
    fi
    if [ "${2:-}" = "daemon" ]; then
      shift 2
      exec "$SCRIPT_DIR/cos-agent-daemon" --project-dir "$PROJECT_ROOT" "$@"
    fi
    echo "cos: unknown agent subcommand '${2:-} ${3:-}'. Try: cos agent {worktree prepare|daemon} ..." >&2
    exit 1
    ;;
  subagent)
    if [ "${2:-}" = "preflight" ]; then
      shift 2
      exec python3 "$SCRIPT_DIR/subagent_launch_preflight.py" "$@"
    fi
    echo "cos: unknown subagent subcommand '${2:-}'. Try: cos subagent preflight --type Explore --prompt '...'" >&2
    exit 1
    ;;
  private-content)
    if [ "${2:-}" = "audit" ]; then
      shift 2
      exec python3 "$SCRIPT_DIR/private_content_audit.py" --project-dir "$PROJECT_ROOT" "$@"
    fi
    if [ "${2:-}" = "check-projection" ]; then
      shift 2
      exec python3 "$SCRIPT_DIR/private_content_audit.py" --project-dir "$PROJECT_ROOT" --check-projection "$@"
    fi
    echo "cos: unknown private-content subcommand '${2:-}'. Try: cos private-content {audit|check-projection PATH} [--json|--strict]" >&2
    exit 1
    ;;
  reward-signal)
    if [ "${2:-}" = "audit" ]; then
      shift 2
      exec "$SCRIPT_DIR/cos-reward-signal-audit" --project-dir "$PROJECT_ROOT" "$@"
    fi
    echo "cos: unknown reward-signal subcommand '${2:-}'. Try: cos reward-signal audit [--json|--strict]" >&2
    exit 1
    ;;
  dependency)
    if [ "${2:-}" = "adoption-gate" ]; then
      shift 2
      exec "$SCRIPT_DIR/cos-dependency-adoption-gate" --project-dir "$PROJECT_ROOT" "$@"
    fi
    echo "cos: unknown dependency subcommand '${2:-}'. Try: cos dependency adoption-gate [--staged|--audit|--json]" >&2
    exit 1
    ;;
  imported-pattern)
    if [ "${2:-}" = "closure-audit" ]; then
      shift 2
      exec "$SCRIPT_DIR/cos-imported-pattern-closure-audit" "$@"
    fi
    echo "cos: unknown imported-pattern subcommand '${2:-}'. Try: cos imported-pattern closure-audit [--json]" >&2
    exit 1
    ;;
  license)
    if [ "${2:-}" = "audit" ]; then
      shift 2
      exec "$SCRIPT_DIR/cos-cross-stack-license-audit" --project-dir "$PROJECT_ROOT" "$@"
    fi
    echo "cos: unknown license subcommand '${2:-}'. Try: cos license audit [--json|--strict]" >&2
    exit 1
    ;;
  secret)
    if [ "${2:-}" = "audit" ]; then
      shift 2
      exec "$SCRIPT_DIR/cos-cross-stack-secret-audit" --project-dir "$PROJECT_ROOT" "$@"
    fi
    echo "cos: unknown secret subcommand '${2:-}'. Try: cos secret audit [--json|--strict]" >&2
    exit 1
    ;;
  publication)
    if [ "${2:-}" = "safety" ]; then
      shift 2
      exec "$SCRIPT_DIR/cos-publication-safety" --project-dir "$PROJECT_ROOT" "$@"
    fi
    echo "cos: unknown publication subcommand '${2:-}'. Try: cos publication safety [--json|--strict]" >&2
    exit 1
    ;;
  adoption)
    if [ "${2:-}" = "audit" ]; then
      shift 2
      exec "$SCRIPT_DIR/cos-cross-stack-adoption-truth" --project-dir "$PROJECT_ROOT" "$@"
    fi
    echo "cos: unknown adoption subcommand '${2:-}'. Try: cos adoption audit [--json|--strict]" >&2
    exit 1
    ;;
  history)
    if [ "${2:-}" = "sanitize" ]; then
      shift 2
      exec "$SCRIPT_DIR/cos-history-sanitization" --project-dir "$PROJECT_ROOT" "$@"
    fi
    echo "cos: unknown history subcommand '${2:-}'. Try: cos history sanitize [--dry-run|--execute] [--json]" >&2
    exit 1
    ;;
  release)
    if [ "${2:-}" = "freeze" ]; then
      shift 2
      exec "$SCRIPT_DIR/cos-release-freeze" --project-dir "$PROJECT_ROOT" "$@"
    fi
    echo "cos: unknown release subcommand '${2:-}'. Try: cos release freeze --prepare|--begin|--status|--end" >&2
    exit 1
    ;;
  public-claim)
    if [ "${2:-}" = "gate" ]; then
      shift 2
      exec "$SCRIPT_DIR/cos-public-claim-gate" --project-dir "$PROJECT_ROOT" "$@"
    fi
    echo "cos: unknown public-claim subcommand '${2:-}'. Try: cos public-claim gate [--json]" >&2
    exit 1
    ;;
  tool-discovery)
    if [ "${2:-}" = "preuse" ]; then
      shift 2
      exec "$SCRIPT_DIR/cos-tool-discovery-preuse" --project-dir "$PROJECT_ROOT" "$@"
    fi
    echo "cos: unknown tool-discovery subcommand '${2:-}'. Try: cos tool-discovery preuse --command CMD [--json]" >&2
    exit 1
    ;;
  mcp)
    if [ "${2:-}" = "registration-plan" ]; then
      shift 2
      exec "$SCRIPT_DIR/cos-mcp-registration-plan" --project-dir "$PROJECT_ROOT" "$@"
    fi
    echo "cos: unknown mcp subcommand '${2:-}'. Try: cos mcp registration-plan [--host HOST] [--json]" >&2
    exit 1
    ;;
  team)
    shift
    exec "$SCRIPT_DIR/cos-team" --project-dir "$PROJECT_ROOT" "$@"
    ;;
  rollback)
    shift
    exec "$SCRIPT_DIR/cos-rollback" --project-dir "$PROJECT_ROOT" "$@"
    ;;
  observe)
    if [ "${2:-}" = "run" ]; then
      shift 2
      exec "$SCRIPT_DIR/cos-run-trace" --project-dir "$PROJECT_ROOT" "$@"
    fi
    if [ "${2:-}" = "primitives" ]; then
      shift 2
      exec "$SCRIPT_DIR/cos-observe-primitives" --project-dir "$PROJECT_ROOT" "$@"
    fi
    echo "cos: unknown observe subcommand '${2:-}'. Try: cos observe {run|primitives} [--session-id ID|--run-id ID] [--json]" >&2
    exit 1
    ;;
  adapters)
    shift
    exec "$SCRIPT_DIR/cos-adapters" --project-dir "$PROJECT_ROOT" "$@"
    ;;
  service)
    if [ "${2:-}" = "readiness" ]; then
      shift 2
      exec "$SCRIPT_DIR/cos-service-readiness-gate" --project-dir "$PROJECT_ROOT" "$@"
    fi
    echo "cos: unknown service subcommand '${2:-}'. Try: cos service readiness [--json]" >&2
    exit 1
    ;;
  performance-ledger)
    if [ "${2:-}" = "compile" ] || [ -z "${2:-}" ] || [[ "${2:-}" == --* ]]; then
      shift
      if [ "${1:-}" = "compile" ]; then
        shift
      fi
      exec "$SCRIPT_DIR/cos-performance-ledger" --project-dir "$PROJECT_ROOT" "$@"
    fi
    echo "cos: unknown performance-ledger subcommand '${2:-}'. Try: cos performance-ledger compile [--json]" >&2
    exit 1
    ;;
  skill-performance)
    if [ "${2:-}" = "ledger" ]; then
      shift 2
      exec "$SCRIPT_DIR/cos-skill-performance-ledger" --project-dir "$PROJECT_ROOT" "$@"
    fi
    echo "cos: unknown skill-performance subcommand '${2:-}'. Try: cos skill-performance ledger [--json]" >&2
    exit 1
    ;;
  promote-from-telemetry)
    shift
    exec "$SCRIPT_DIR/cos-promote-from-telemetry" --project-dir "$PROJECT_ROOT" "$@"
    ;;
  maintainer)
    if [ "${2:-}" = "once" ]; then
      shift 2
      exec "$SCRIPT_DIR/cos-maintainer-agent" --project-dir "$PROJECT_ROOT" --once "$@"
    fi
    echo "cos: unknown maintainer subcommand '${2:-}'. Try: cos maintainer once --dry-run [--json]" >&2
    exit 1
    ;;
  adr)
    if [ "${2:-}" = "resolve" ]; then
      shift 2
      exec "$SCRIPT_DIR/cos-adr-resolve" --project-dir "$PROJECT_ROOT" "$@"
    fi
    echo "cos: unknown adr subcommand '${2:-}'. Try: cos adr resolve ADR_NUMBER [--expect-title TEXT] [--json]" >&2
    exit 1
    ;;
  worktree)
    if [ "${2:-}" = "audit" ]; then
      shift 2
      exec "$SCRIPT_DIR/cos-worktree-audit" --project-dir "$PROJECT_ROOT" "$@"
    fi
    echo "cos: unknown worktree subcommand '${2:-}'. Try: cos worktree audit [--json|--strict] [--against REF]" >&2
    exit 1
    ;;
  work)
    if [ "${2:-}" = "ownership" ]; then
      shift 2
      if [ "${1:-}" = "--paths" ]; then
        shift
      fi
      exec python3 "$SCRIPT_DIR/cos_work_inventory.py" --project-dir "$PROJECT_ROOT" --all --paths "$@"
    fi
    echo "cos: unknown work subcommand '${2:-}'. Try: cos work ownership PATH [PATH...]" >&2
    exit 1
    ;;
  state)
    if [ "${2:-}" = "retention" ]; then
      shift 2
      exec python3 "$SCRIPT_DIR/state_retention_audit.py" --project-dir "$PROJECT_ROOT" "$@"
    fi
    echo "cos: unknown state subcommand '${2:-}'. Try: cos state retention" >&2
    exit 1
    ;;
  stash)
    if [ "${2:-}" = "cleanup" ]; then
      shift 2
      exec python3 "$SCRIPT_DIR/state_retention_audit.py" --project-dir "$PROJECT_ROOT" --surface auto-pre-agent-stashes --reap "$@"
    fi
    echo "cos: unknown stash subcommand '${2:-}'. Try: cos stash cleanup [--execute]" >&2
    exit 1
    ;;
  help|-h|--help|"")
    cat <<EOF
cos — Cognitive OS command-line

Usage:
  cos status [--verbose|--json|--help]   Show what is active (profile, skills, hooks, rules, health)
  cos coverage [--json|--brief|--refresh] Show ACC coverage with exit code + JSON contract
  cos tui --snapshot                     Show primitive surface snapshot
  cos tui --operate refresh-all --confirm Operate whitelisted report refresh with receipt
  cos primitive harness-coverage [--print-json] Generate primitive surface coverage
  cos primitive surface-coverage [--print-json] Alias for primitive harness coverage
  cos init-check                         Check the minimal harness readiness path
  cos doctor harness [--json]            Check active harness projection and minimal profile
  cos measure harness-profiles [--json]  Compare minimal vs full harness surface
  cos governance roi [--json]            Estimate governance friction vs benefit
  cos governance readiness [--json]      Report architecture readiness and remaining gaps
  cos land [--dry-run]                   Land current branch through protected merge-to-main path
  cos merge queue ...                    Operate the local merge queue
  cos sprint <cmd>                       Run sprint orchestration commands
  cos subagent preflight --type TYPE --prompt TEXT
  cos agent worktree prepare --task-id ID --session-id ID [--json]
  cos agent daemon enqueue|run-once|list|reap ...
                                         Queue and launch opt-in detached local agents
                                         Check subagent capability contract before launch
  cos private-content audit [--json]      Audit ADR-202 private-content classifications
  cos private-content check-projection PATH [--destination cloud|local] [--json]
                                         Block unsafe private-content export/projection
  cos reward-signal audit [--json]        Audit ADR-204 reward signal quality
  cos dependency adoption-gate [--staged|--audit|--json]
                                         Enforce ADR-208 pre-adoption evidence for dependency changes
  cos imported-pattern closure-audit [--json]
                                         Audit ADR-208 imported producer/consumer/evaluator closure contracts
  cos secret audit [--json|--strict]     Audit ADR-215 secret scanner posture and sensitive surfaces
  cos publication safety [--json|--strict]
                                         Run project-configured publication-safety gates
  cos adoption audit [--json|--strict]   Audit ADR-217 lockfile/NOTICE/docs adoption truth
  cos history sanitize [--dry-run|--execute] [--json]
                                         Audit ADR-218 pre-public git history sanitization plan
  cos release freeze --prepare|--begin|--status|--end
                                         Create/check ADR-246 release transaction freeze receipts
  cos public-claim gate [--json]        Block unbacked ADR-206 public autonomous/self-improvement claims
  cos observe run [--session-id ID|--run-id ID] [--json]
  cos observe primitives [--session-id ID|--run-id ID] [--json]
  cos adapters list|verify|install HARNESS [--json]
  cos adapters compile HARNESS --output DIR [--mode default|full] [--dry-run] [--json]
  cos rollback --session-id ID --snapshot|--preview|--restore [--tree-sha SHA] [--yes]
  cos team join|task|message|inbox|handoff ...
                                         Coordinate ADR-233 file-IPC teams and ADR-230 inbox handoffs
                                         Join metric streams into ADR-205 run trace
  cos service readiness [--json]         Aggregate ADR-211 service-mode readiness gates
  cos performance-ledger compile [--json] Compile ADR-201 SQLite performance ledger
  cos skill-performance ledger [--json] Project ADR-207 skill lifecycle proposals from clean reward signals
  cos promote-from-telemetry [--json]    Convert consumable telemetry into bounded proposals
  cos maintainer once --dry-run [--json] Run proposer-only maintainer loop once
  cos adr resolve N [--expect-title T]   Resolve ADR number against canonical docs/02-Decisions/adrs state
  cos work ownership PATH [PATH...]      Join WIP/stash/worktree/claim/process signals for selected paths
  cos worktree audit [--json|--strict]    Audit linked worktree divergence against main/upstream
  cos state retention [--json|--strict]   Audit declared mutable state retention
  cos stash cleanup [--json|--execute]    Archive-first cleanup for stale auto-pre-agent stashes
  cos init [dir]                         Install Cognitive OS into a project
  cos doctor                             Check installation health
  cos list [type]                        List installed agentic primitives
  cos install <type> <name>              Install an agentic primitive
  cos search <query>                     Search agentic primitives across sources
  cos version                            Show version

  cos help                               This help

Routed to bin/cognitive-os.sh: init, doctor, list, install, uninstall, search,
sources, update, version.

Routed to scripts/cos-status.sh: status.
Routed to scripts/cos-coverage: coverage.
Routed to scripts/cos-tui: tui.
Routed to scripts/primitive_harness_coverage.py: primitive harness-coverage, primitive surface-coverage.
EOF
    exit 0
    ;;
  *)
    # Delegate all other subcommands to the existing full CLI
    FULL_CLI="$PROJECT_ROOT/bin/cognitive-os.sh"
    if [ ! -x "$FULL_CLI" ]; then
      echo "cos: bin/cognitive-os.sh not found or not executable at $FULL_CLI" >&2
      exit 1
    fi
    exec bash "$FULL_CLI" "$@"
    ;;
esac
