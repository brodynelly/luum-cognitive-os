#!/usr/bin/env python3
from __future__ import annotations
import argparse, sys
from pathlib import Path
ROOT=Path(__file__).resolve().parents[1]
if str(ROOT) not in sys.path: sys.path.insert(0,str(ROOT))
from lib.feature_tool_due_diligence import benchmark_due_diligence, write_json

def main() -> int:
    p=argparse.ArgumentParser(description="Check ADR-255 feature-vs-tool benchmark/source evidence records.")
    p.add_argument("--manifest", default="manifests/feature-tool-due-diligence.yaml")
    p.add_argument("--json", action="store_true")
    a=p.parse_args(); path=Path(a.manifest)
    if not path.is_absolute(): path=ROOT/path
    report=benchmark_due_diligence(path)
    print(write_json(report), end="")
    return 1 if report["status"] == "block" else 0
if __name__ == "__main__": raise SystemExit(main())
