#!/usr/bin/env python3
# SCOPE: both
from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
if str(ROOT) not in sys.path:
    sys.path.insert(0, str(ROOT))

from lib.repo_map import build_repo_map

parser = argparse.ArgumentParser(description="Build a COS repo-map context packet")
parser.add_argument("query")
parser.add_argument("--project-dir", default=".")
parser.add_argument("--max-tokens", type=int, default=1200)
parser.add_argument("--changed-file", action="append", default=[])
args = parser.parse_args()
print(json.dumps(build_repo_map(args.project_dir, args.query, max_tokens=args.max_tokens, changed_files=args.changed_file).to_dict(), indent=2, sort_keys=True))
