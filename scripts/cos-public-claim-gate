#!/usr/bin/env python3
"""CLI for ADR-206 public claim decommission gate."""
from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
if str(ROOT) not in sys.path:
    sys.path.insert(0, str(ROOT))

from lib.public_claim_gate import scan  # noqa: E402


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--project-dir", type=Path, default=ROOT)
    parser.add_argument("--manifest", type=Path)
    parser.add_argument("--json", action="store_true")
    args = parser.parse_args()

    report = scan(args.project_dir.resolve(), args.manifest)
    if args.json:
        print(json.dumps(report, indent=2, sort_keys=True))
    else:
        print(f"public-claim-gate: {report['status']} findings={report['finding_count']}")
        for finding in report["findings"][:20]:
            print(f"- {finding['path']}:{finding['line']} {finding['pattern']}: {finding['text']}")
    return 2 if report["status"] == "fail" else 0


if __name__ == "__main__":
    raise SystemExit(main())

