#!/usr/bin/env bash
# commit-msg — block AI-provider-looking invented co-author identities.
set -euo pipefail

REPO_DIR=$(git rev-parse --show-toplevel 2>/dev/null || exit 0)
MSG_FILE="$1"
[ -n "$MSG_FILE" ] || exit 0
[ -f "$MSG_FILE" ] || exit 0

if [ -x "$REPO_DIR/scripts/ai-provider-identity-guard" ]; then
  "$REPO_DIR/scripts/ai-provider-identity-guard" --project-dir "$REPO_DIR" --commit-msg "$MSG_FILE" || exit 1
fi
exit 0
