name: Primitive Gap Audit

on:
  schedule:
    - cron: '30 12 * * MON'  # every Monday 12:30 UTC, after public metrics
  workflow_dispatch: {}

jobs:
  primitive-gap-snapshot:
    runs-on: ubuntu-latest
    permissions:
      contents: write
    steps:
      - uses: actions/checkout@v4
        with:
          token: ${{ github.token }}

      - name: Generate primitive gap snapshot
        run: |
          python3 scripts/primitive_gap_snapshot.py \
            --trend \
            --trend-path docs/06-Daily/reports/primitive-gap-history.jsonl \
            --markdown docs/06-Daily/reports/primitive-gap-latest.md \
            --regression-report docs/06-Daily/reports/primitive-gap-regressions.md \
            --fail-on-regression \
            --fail-on-gap \
            --json > docs/06-Daily/reports/primitive-gap-latest.json

      - name: Run documentation duplicate audit
        run: |
          python3 scripts/docs_duplicate_audit.py \
            --baseline docs/06-Daily/reports/docs-duplicate-baseline.json \
            --markdown docs/06-Daily/reports/docs-duplicate-latest.md \
            --fail-new \
            --json > docs/06-Daily/reports/docs-duplicate-latest.json

      - name: Run primitive row audit
        run: |
          python3 scripts/primitive_row_audit.py \
            --json-out docs/06-Daily/reports/primitive-row-audit-latest.json \
            --md-out docs/06-Daily/reports/primitive-row-audit-latest.md

      - name: Run claim-to-proof audit
        run: |
          python3 scripts/claim_proof_audit.py \
            --json-out docs/06-Daily/reports/claim-proof-latest.json \
            --md-out docs/06-Daily/reports/claim-proof-latest.md \
            --fail-unmapped

      - name: Generate reduction backlog
        run: |
          python3 scripts/reduction_backlog.py \
            --row-audit docs/06-Daily/reports/primitive-row-audit-latest.json \
            --claim-audit docs/06-Daily/reports/claim-proof-latest.json \
            --json-out docs/06-Daily/reports/reduction-backlog-latest.json \
            --md-out docs/06-Daily/reports/reduction-backlog-latest.md \
            --fail-nonzero

      - name: Plan hook surface reduction
        run: |
          python3 scripts/primitive_surface_reduce.py \
            --family hooks \
            --plan \
            --json-out docs/06-Daily/reports/primitive-surface-reduction-latest.json \
            --md-out docs/06-Daily/reports/primitive-surface-reduction-latest.md

      - name: Map primitive consumers
        run: |
          python3 scripts/primitive_usage_map.py \
            --target-family scripts \
            --json-out docs/06-Daily/reports/primitive-usage-map-latest.json \
            --md-out docs/06-Daily/reports/primitive-usage-map-latest.md

      - name: Generate generic primitive coverage reports
        run: |
          python3 scripts/primitive_coverage.py \
            --adapter cognitive-os \
            --format json \
            --out docs/06-Daily/reports/primitive-coverage-latest.json
          python3 scripts/primitive_coverage.py \
            --adapter cognitive-os \
            --format markdown \
            --out docs/06-Daily/reports/primitive-coverage-latest.md
          python3 scripts/primitive_coverage.py \
            --adapter cognitive-os \
            --format sarif \
            --out docs/06-Daily/reports/primitive-coverage-latest.sarif \
            --fail-actionable-gaps

      - name: Run documentation execution audit
        run: |
          python3 scripts/docs_execution_audit.py \
            --json-out docs/06-Daily/reports/docs-execution-latest.json \
            --md-out docs/06-Daily/reports/docs-execution-latest.md \
            --fail-hard-gaps

      - name: Upload primitive gap snapshot artifact
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: primitive-gap-snapshot
          path: |
            docs/06-Daily/reports/primitive-gap-latest.json
            docs/06-Daily/reports/primitive-gap-latest.md
            docs/06-Daily/reports/primitive-gap-regressions.md
            docs/06-Daily/reports/primitive-gap-history.jsonl
            docs/06-Daily/reports/docs-duplicate-baseline.json
            docs/06-Daily/reports/docs-duplicate-latest.json
            docs/06-Daily/reports/docs-duplicate-latest.md
            docs/06-Daily/reports/primitive-row-audit-latest.json
            docs/06-Daily/reports/primitive-row-audit-latest.md
            docs/06-Daily/reports/claim-proof-latest.json
            docs/06-Daily/reports/claim-proof-latest.md
            docs/06-Daily/reports/reduction-backlog-latest.json
            docs/06-Daily/reports/reduction-backlog-latest.md
            docs/06-Daily/reports/primitive-surface-reduction-latest.json
            docs/06-Daily/reports/primitive-surface-reduction-latest.md
            docs/06-Daily/reports/primitive-usage-map-latest.json
            docs/06-Daily/reports/primitive-usage-map-latest.md
            docs/06-Daily/reports/primitive-coverage-latest.json
            docs/06-Daily/reports/primitive-coverage-latest.md
            docs/06-Daily/reports/primitive-coverage-latest.sarif
            docs/06-Daily/reports/docs-execution-latest.json
            docs/06-Daily/reports/docs-execution-latest.md

      - name: Commit primitive gap trend
        run: |
          git config user.name "cognitive-os-bot"
          git config user.email "bot@luum.ai"
          git add \
            docs/06-Daily/reports/primitive-gap-latest.json \
            docs/06-Daily/reports/primitive-gap-latest.md \
            docs/06-Daily/reports/primitive-gap-regressions.md \
            docs/06-Daily/reports/primitive-gap-history.jsonl \
            docs/06-Daily/reports/docs-duplicate-latest.json \
            docs/06-Daily/reports/docs-duplicate-latest.md \
            docs/06-Daily/reports/primitive-row-audit-latest.json \
            docs/06-Daily/reports/primitive-row-audit-latest.md \
            docs/06-Daily/reports/claim-proof-latest.json \
            docs/06-Daily/reports/claim-proof-latest.md \
            docs/06-Daily/reports/reduction-backlog-latest.json \
            docs/06-Daily/reports/reduction-backlog-latest.md \
            docs/06-Daily/reports/primitive-surface-reduction-latest.json \
            docs/06-Daily/reports/primitive-surface-reduction-latest.md \
            docs/06-Daily/reports/primitive-usage-map-latest.json \
            docs/06-Daily/reports/primitive-usage-map-latest.md \
            docs/06-Daily/reports/primitive-coverage-latest.json \
            docs/06-Daily/reports/primitive-coverage-latest.md \
            docs/06-Daily/reports/primitive-coverage-latest.sarif \
            docs/06-Daily/reports/docs-execution-latest.json \
            docs/06-Daily/reports/docs-execution-latest.md
          git diff --staged --quiet || git commit -m "chore(audit): weekly primitive gap snapshot $(date -u +%Y-%m-%d)"
          git push
