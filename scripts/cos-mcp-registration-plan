#!/usr/bin/env python3
# SCOPE: os-only
"""Emit ADR-231 MCP registration plans for supported hosts."""
from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path
from typing import Any

try:
    import yaml
except ImportError:  # pragma: no cover
    yaml = None  # type: ignore

ROOT = Path(__file__).resolve().parents[1]


def load_manifest(path: Path) -> dict[str, Any]:
    if yaml is None:
        raise SystemExit("PyYAML is required for cos-mcp-registration-plan")
    return yaml.safe_load(path.read_text(encoding="utf-8"))


def build_plan(project_dir: Path, host: str | None = None, transport: str = "stdio") -> dict[str, Any]:
    manifest = load_manifest(ROOT / "manifests" / "mcp-server-registration.yaml")
    base_server = dict(manifest["server"])
    transport_cfg = dict(base_server.get("transports", {}).get(transport, {}))
    if not transport_cfg:
        raise SystemExit(f"unsupported MCP transport in manifest: {transport}")
    server = {k: v for k, v in base_server.items() if k != "transports"}
    server["transport"] = transport
    if transport == "streamable-http":
        server.pop("command", None)
        server.pop("args", None)
        server["url"] = transport_cfg.get("default_url", "http://127.0.0.1:8765/mcp")
        server["trust_pin_required"] = bool(transport_cfg.get("trust_pin_required", True))
    else:
        server["command"] = transport_cfg.get("command", server.get("command"))
        server["args"] = [str((project_dir / arg).resolve()) if arg == "mcp-server/cos_mcp.py" else arg for arg in transport_cfg.get("args", server.get("args", []))]
    server["cwd"] = str(project_dir.resolve())
    hosts = manifest["hosts"]
    selected = {host: hosts[host]} if host else hosts
    plans = []
    for name, cfg in selected.items():
        if not cfg.get("supported", False):
            continue
        plans.append({
            "host": name,
            "config_path": cfg["config_path"],
            "key_path": cfg["key_path"],
            "server": server,
        })
    return {"schema_version": "mcp-server-registration-plan/v1", "plans": plans}


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--project-dir", default=str(ROOT))
    parser.add_argument("--host", choices=["claude-code", "codex", "cursor", "devin"])
    parser.add_argument("--transport", choices=["stdio", "streamable-http"], default="stdio")
    parser.add_argument("--json", action="store_true")
    args = parser.parse_args()
    plan = build_plan(Path(args.project_dir), host=args.host, transport=args.transport)
    if args.json:
        print(json.dumps(plan, indent=2, sort_keys=True))
    else:
        for item in plan["plans"]:
            server = item["server"]
            if server.get("transport") == "streamable-http":
                print(f"{item['host']}: {item['config_path']} -> {item['key_path']} :: {server['url']} trust_pin_required={server.get('trust_pin_required')}")
            else:
                print(f"{item['host']}: {item['config_path']} -> {item['key_path']} :: {server['command']} {' '.join(server['args'])}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
