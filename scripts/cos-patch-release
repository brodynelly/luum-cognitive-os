#!/usr/bin/env python3
# SCOPE: both
"""Patch-release primitive for Cognitive OS.

Subcommands:
  prepare   bump release metadata, changelog, and uv.lock
  validate  run the patch-release validation lane
  plan      print the complete land + prepare + publish sequence
  publish   branch/commit/merge/tag/watch without direct main push
  doctor    diagnose release hazards before publishing
"""

from __future__ import annotations

import argparse
import json
import os
import re
import shutil
import subprocess
import sys
import time
from dataclasses import dataclass
from datetime import date
from pathlib import Path
from typing import Sequence

RELEASE_FILES = ["VERSION", "cmd/cos/VERSION", "pyproject.toml", "uv.lock", "CHANGELOG.md"]
PATCH_VALIDATE_CMD = "scripts/cos-patch-release validate"
PATCH_MERGE_CMD = [
    "scripts/merge-to-main.sh",
    "--validate",
    PATCH_VALIDATE_CMD,
    "--recommended-lane",
    "patch-release",
    "--executed-lane",
    "patch-release",
]
PATCH_VALIDATION_COMMANDS = [
    ["bash", "-n", "scripts/check-local-privacy.sh", ".githooks/pre-commit", "hooks/provenance-scan.sh", "scripts/provenance-scan"],
    ["scripts/check-local-privacy.sh", "--root", ".", "--all"],
    ["scripts/provenance-scan", "--json"],
    ["python3", "scripts/check_bun_install_policy.py", "--json"],
    [
        ".venv/bin/python",
        "-m",
        "pytest",
        "tests/unit/test_check_absolute_paths.py",
        "tests/unit/test_check_local_privacy.py",
        "tests/red_team/portability/test_check-local-privacy.py",
        "tests/red_team/portability/test_local-privacy-hygiene.py",
        "-q",
    ],
    [
        ".venv/bin/python",
        "-m",
        "pytest",
        "tests/contracts/test_orphan_hooks.py",
        "tests/audit/test_hook_registration_classification.py",
        "tests/contracts/test_primitive_runtime_reality.py",
        "tests/unit/test_cognitive_os_yaml_harness_hooks.py",
        "tests/unit/test_runtime_hook_reality.py",
        "tests/behavior/test_research_compliance_guard.py",
        "-q",
    ],
    ["go", "test", "./..."],
]
SEMVER_RE = re.compile(r"^v?(\d+)\.(\d+)\.(\d+)$")
PYPROJECT_VERSION_RE = re.compile(r'^version = "[^"]+"$', re.MULTILINE)


@dataclass(frozen=True)
class CommandResult:
    args: Sequence[str]
    returncode: int
    stdout: str = ""
    stderr: str = ""


def run(
    args: Sequence[str],
    *,
    cwd: Path,
    check: bool = True,
    capture: bool = False,
    env: dict[str, str] | None = None,
) -> CommandResult:
    proc = subprocess.run(
        list(args),
        cwd=str(cwd),
        text=True,
        stdout=subprocess.PIPE if capture else None,
        stderr=subprocess.PIPE if capture else None,
        check=False,
        env=env,
    )
    result = CommandResult(args=args, returncode=proc.returncode, stdout=proc.stdout or "", stderr=proc.stderr or "")
    if check and result.returncode != 0:
        cmd = " ".join(args)
        if capture:
            sys.stderr.write(result.stdout)
            sys.stderr.write(result.stderr)
        raise SystemExit(f"ERROR: command failed ({result.returncode}): {cmd}")
    return result


def git(root: Path, *args: str, check: bool = True, capture: bool = True) -> CommandResult:
    return run(["git", *args], cwd=root, check=check, capture=capture)


def find_root(raw: str | None) -> Path:
    if raw:
        return Path(raw).resolve()
    proc = subprocess.run(["git", "rev-parse", "--show-toplevel"], text=True, capture_output=True, check=False)
    if proc.returncode == 0 and proc.stdout.strip():
        return Path(proc.stdout.strip()).resolve()
    return Path.cwd().resolve()


def normalize_version(version: str) -> tuple[str, str]:
    match = SEMVER_RE.fullmatch(version.strip())
    if not match:
        raise SystemExit(f"ERROR: invalid patch release version: {version!r}")
    bare = ".".join(match.groups())
    return bare, f"v{bare}"


def current_version(root: Path) -> str:
    version_file = root / "VERSION"
    if not version_file.exists():
        raise SystemExit("ERROR: VERSION file not found")
    return version_file.read_text(encoding="utf-8").strip()


def ensure_patch_increment(root: Path, bare: str) -> None:
    current = current_version(root)
    cur = SEMVER_RE.fullmatch(current)
    nxt = SEMVER_RE.fullmatch(bare)
    if not cur or not nxt:
        return
    cur_tuple = tuple(int(x) for x in cur.groups())
    nxt_tuple = tuple(int(x) for x in nxt.groups())
    if nxt_tuple <= cur_tuple:
        raise SystemExit(f"ERROR: target version {bare} must be greater than current {current}")


def tracked_status(root: Path) -> str:
    return git(root, "status", "--porcelain=v1", "--untracked-files=no").stdout


def tag_exists(root: Path, tag: str) -> tuple[bool, bool]:
    local = git(root, "rev-parse", "-q", "--verify", f"refs/tags/{tag}", check=False).returncode == 0
    remote = git(root, "ls-remote", "--exit-code", "--tags", "origin", f"refs/tags/{tag}", check=False).returncode == 0
    return local, remote


def replace_pyproject_version(path: Path, bare: str) -> None:
    text = path.read_text(encoding="utf-8")
    new_text, count = PYPROJECT_VERSION_RE.subn(f'version = "{bare}"', text, count=1)
    if count != 1:
        raise SystemExit("ERROR: pyproject.toml version field not found")
    path.write_text(new_text, encoding="utf-8")


def ensure_changelog_entry(root: Path, bare: str, title: str) -> None:
    path = root / "CHANGELOG.md"
    text = path.read_text(encoding="utf-8")
    marker = "## [Unreleased]\n\n"
    if f"## [{bare}]" in text:
        return
    today = date.today().isoformat()
    entry = (
        f"## [Unreleased]\n\n"
        f"## [{bare}] - {today} — \"{title}\"\n\n"
        "### Added\n"
        "- Added the `cos-patch-release` primitive for repeatable patch release preparation, validation, publishing, and diagnostics.\n\n"
        "### Validation\n"
        "- `scripts/cos-patch-release validate` is the required patch-release validation lane.\n\n"
    )
    if marker not in text:
        raise SystemExit("ERROR: CHANGELOG.md missing Unreleased marker")
    path.write_text(text.replace(marker, entry, 1), encoding="utf-8")


def prepare(args: argparse.Namespace) -> int:
    root = find_root(args.project_dir)
    bare, tag = normalize_version(args.version)
    ensure_patch_increment(root, bare)
    local_tag, remote_tag = tag_exists(root, tag)
    if local_tag or remote_tag:
        raise SystemExit(f"ERROR: tag {tag} already exists (local={local_tag} remote={remote_tag})")

    title = args.title or "Patch Release Primitive"
    planned = {
        "version": bare,
        "tag": tag,
        "files": RELEASE_FILES,
        "commands": ["uv lock", "uv sync --extra testing --locked"],
    }
    if args.dry_run:
        print(json.dumps({"status": "dry-run", "prepare": planned}, indent=2, sort_keys=True))
        return 0

    (root / "VERSION").write_text(bare + "\n", encoding="utf-8")
    (root / "cmd/cos/VERSION").write_text(bare + "\n", encoding="utf-8")
    replace_pyproject_version(root / "pyproject.toml", bare)
    ensure_changelog_entry(root, bare, title)
    run(["uv", "lock"], cwd=root)
    lock_before = (root / "uv.lock").read_bytes()
    run(["uv", "sync", "--extra", "testing", "--locked"], cwd=root)
    lock_after = (root / "uv.lock").read_bytes()
    if lock_before != lock_after:
        raise SystemExit("ERROR: uv sync --locked changed uv.lock; run uv lock and retry")
    print(f"patch-release-prepare-ok version={bare} tag={tag}")
    return 0


def validate(args: argparse.Namespace) -> int:
    root = find_root(args.project_dir)
    commands = PATCH_VALIDATION_COMMANDS
    if args.print_commands:
        for command in commands:
            display = " ".join(command)
            if command == ["go", "test", "./..."]:
                display = "cd cmd/cos && go test ./..."
            print(display)
        return 0
    for command in commands:
        cwd = root / "cmd/cos" if command == ["go", "test", "./..."] else root
        env = os.environ.copy()
        if "pytest" in command:
            env.setdefault("PYTEST_DISABLE_PLUGIN_AUTOLOAD", "1")
        run(command, cwd=cwd, env=env)
    print("patch-release-validate-ok")
    return 0


def release_flow_plan(args: argparse.Namespace) -> int:
    root = find_root(args.project_dir)
    bare, tag = normalize_version(args.version)
    branch = args.branch or f"codex/release-v{bare}"
    title = args.title or "Patch Release"
    current = git(root, "branch", "--show-current", check=False).stdout.strip() or "<current-branch>"
    payload = {
        "status": "dry-run",
        "version": bare,
        "tag": tag,
        "current_branch": current,
        "release_branch": branch,
        "policy": {
            "direct_main_push": "forbidden",
            "landing_path": "scripts/merge-to-main.sh",
            "validation_lane": PATCH_VALIDATE_CMD,
            "release_type": "patch",
        },
        "steps": [
            {
                "name": "land_current_branch",
                "when": "current branch contains feature/fix commits not on main",
                "command": " ".join(PATCH_MERGE_CMD),
            },
            {
                "name": "prepare_release",
                "command": f"scripts/cos-patch-release prepare --version {bare} --title {title!r}",
            },
            {
                "name": "supply_chain_policy",
                "command": "scripts/check_bun_install_policy.py --json",
            },
            {
                "name": "validate_release",
                "command": PATCH_VALIDATE_CMD,
            },
            {
                "name": "doctor_release_contract",
                "command": f"scripts/cos-patch-release doctor --version {bare} --strict --contract-only --json",
            },
            {
                "name": "create_release_branch",
                "command": f"git switch -c {branch}",
            },
            {
                "name": "commit_release_delta",
                "command": "git add CHANGELOG.md VERSION cmd/cos/VERSION pyproject.toml uv.lock && git commit -m 'release: v%s'" % bare,
            },
            {
                "name": "push_release_branch",
                "command": f"git push -u origin {branch}",
            },
            {
                "name": "land_release_branch",
                "command": " ".join(PATCH_MERGE_CMD),
            },
            {
                "name": "tag_release",
                "command": f"git tag -a {tag} -m {tag} && git push origin {tag}",
            },
            {
                "name": "watch_release_workflow",
                "command": f"gh run watch <run-id> --repo {args.repo} --exit-status",
            },
            {
                "name": "verify_github_release",
                "command": f"gh release view {tag} --repo {args.repo}",
            },
        ],
    }
    print(json.dumps(payload, indent=2, sort_keys=True))
    return 0



def strict_release_contract_checks(root: Path) -> list[dict[str, object]]:
    checks: list[dict[str, object]] = []

    def add(name: str, ok: bool, detail: str, blocking: bool = True) -> None:
        checks.append({"name": name, "ok": ok, "blocking": blocking, "detail": detail})

    lane_file = root / ".cognitive-os" / "test-lanes.yaml"
    lane_text = lane_file.read_text(encoding="utf-8") if lane_file.exists() else ""
    add("lane_semantics_declared", "gate_class:" in lane_text and "failure_policy:" in lane_text, "every release lane must declare gate_class and failure_policy")
    add("integration_sublanes_declared", all(name in lane_text for name in ("integration-installer", "integration-memory", "integration-hooks", "integration-runtime")), "integration must be split into installer/memory/hooks/runtime sublanes")

    broad_source = (root / "cmd/cos-test/internal/cli/broad.go").read_text(encoding="utf-8")
    add("broad_json_strict_supported", "broadJSON" in broad_source and "broadStrict" in broad_source, "cos-test broad must expose --json and --strict")
    add("release_validate_subcommand", "releaseValidateCmd" in (root / "cmd/cos/internal/cli/release.go").read_text(encoding="utf-8"), "cos release validate must be registered")
    add("harness_projection_policy", (root / "manifests/harness-hook-projection-policy.yaml").exists(), "harness projection policy manifest must exist")

    derived = run(["python3", "scripts/derived_artifact_gate.py"], cwd=root, check=False, capture=True)
    add("derived_artifacts_clean", derived.returncode == 0, "derived_artifact_gate.py must pass")

    broad = run(["go", "run", ".", "broad", "--dry-run", "--no-docker", "--json"], cwd=root / "cmd/cos-test", check=False, capture=True)
    add("broad_json_dry_run", broad.returncode == 0 and "cos-test-broad-summary/v1" in broad.stdout, "cos-test broad --dry-run --no-docker --json must emit summary")
    add("broad_no_docker_skips_docker", broad.returncode == 0 and ("docker_policy=required" in (broad.stdout + broad.stderr) or "skipping optional" in (broad.stdout + broad.stderr)), "no-docker broad should either skip Docker lanes explicitly or exclude optional Docker lanes", blocking=False)

    integration_coverage = run(["scripts/check_integration_lane_coverage.py", "--strict", "--json"], cwd=root, check=False, capture=True)
    add("integration_lane_coverage", integration_coverage.returncode == 0 and "integration-lane-coverage/v1" in integration_coverage.stdout, "every integration test file must be assigned to exactly one non-Docker integration sublane")

    quarantine = run(["go", "run", ".", "quarantine", "audit", "--json"], cwd=root / "cmd/cos-test", check=False, capture=True)
    add("test_quarantine_audit", quarantine.returncode == 0 and "test-quarantine-audit/v1" in quarantine.stdout, "formal test quarantine manifest must be valid and unexpired")

    classifier_exists = (root / "scripts/cos-classify-failures").exists()
    ledger = run(["scripts/cos-test-reliability-ledger", "compile", "--project-dir", str(root), "--json"], cwd=root, check=False, capture=True)
    add("failure_classifier_available", classifier_exists, "cos-classify-failures must exist for per-node failure taxonomy")
    add("reliability_ledger_compiles", ledger.returncode == 0 and "test-reliability-ledger/v1" in ledger.stdout, "test reliability ledger must compile historical lane outcomes")
    return checks

def doctor(args: argparse.Namespace) -> int:
    root = find_root(args.project_dir)
    bare, tag = normalize_version(args.version or current_version(root))
    checks: list[dict[str, object]] = []

    def add(name: str, ok: bool, detail: str, blocking: bool = True) -> None:
        checks.append({"name": name, "ok": ok, "blocking": blocking, "detail": detail})

    if not getattr(args, "contract_only", False):
        local_tag, remote_tag = tag_exists(root, tag)
        add("tag_available", not (local_tag or remote_tag), f"{tag} local={local_tag} remote={remote_tag}")
        add("gh_available", shutil.which("gh") is not None, "gh CLI is required for publish")
        gh_ok = shutil.which("gh") is not None and run(["gh", "auth", "status"], cwd=root, check=False, capture=True).returncode == 0
        add("gh_authenticated", gh_ok, "gh auth status must pass")
    workflow = root / ".github/workflows/cos-binary-release.yml"
    workflow_text = workflow.read_text(encoding="utf-8") if workflow.exists() else ""
    add("release_workflow_locked_uv", "uv sync --extra testing --locked" in workflow_text, "cos-binary-release must use locked uv sync")
    add("release_workflow_patch_lane", "scripts/cos-patch-release validate" in workflow_text or "test_check_local_privacy.py" in workflow_text, "cos-binary-release must use patch-release validation lane")
    add("direct_main_guard", "COS_MERGE_TO_MAIN" in (root / ".git/hooks/pre-push").read_text(encoding="utf-8", errors="ignore") if (root / ".git/hooks/pre-push").exists() else True, "direct main push should be guarded", blocking=False)

    if not getattr(args, "contract_only", False):
        dirty_before = tracked_status(root)
        if dirty_before:
            add("working_tree_clean", False, "tracked working tree has changes")
        else:
            lock_before = (root / "uv.lock").read_bytes() if (root / "uv.lock").exists() else b""
            sync = run(["uv", "sync", "--extra", "testing", "--locked"], cwd=root, check=False, capture=True)
            lock_after = (root / "uv.lock").read_bytes() if (root / "uv.lock").exists() else b""
            add("uv_locked_sync_clean", sync.returncode == 0 and lock_before == lock_after, "uv sync --locked must not dirty uv.lock")

        scope_runs = run(["gh", "run", "list", "--repo", args.repo, "--workflow", "scope-portability.yml", "--limit", "1", "--json", "status,conclusion,url"], cwd=root, check=False, capture=True) if shutil.which("gh") else CommandResult([], 1)
        scope_detail = "scope portability status unavailable"
        scope_ok = True
        if scope_runs.returncode == 0 and scope_runs.stdout.strip():
            try:
                rows = json.loads(scope_runs.stdout)
                if rows:
                    scope_detail = json.dumps(rows[0], sort_keys=True)
                    scope_ok = rows[0].get("conclusion") in {"success", None, ""}
            except json.JSONDecodeError:
                pass
        add("scope_portability_latest", scope_ok, scope_detail, blocking=False)

    if getattr(args, "strict", False):
        checks.extend(strict_release_contract_checks(root))

    status = "pass" if all(c["ok"] or not c["blocking"] for c in checks) else "block"
    payload = {"status": status, "version": bare, "tag": tag, "checks": checks}
    if args.json:
        print(json.dumps(payload, indent=2, sort_keys=True))
    else:
        print(f"release-doctor: {status} version={bare} tag={tag}")
        for check in checks:
            prefix = "OK" if check["ok"] else ("WARN" if not check["blocking"] else "BLOCK")
            print(f"- {prefix} {check['name']}: {check['detail']}")
    return 0 if status == "pass" or args.allow_warnings else 1


def publish(args: argparse.Namespace) -> int:
    root = find_root(args.project_dir)
    bare, tag = normalize_version(args.version)
    branch = args.branch or f"codex/release-v{bare}"
    message = args.message or f"release: v{bare}"
    plan = {
        "version": bare,
        "tag": tag,
        "branch": branch,
        "commit": message,
        "steps": [
            f"git switch -c {branch} (if on main)",
            "git add -A (stage the prepared release delta; never push direct main)",
            f"git commit -m {message!r}",
            f"git push -u origin {branch}",
            " ".join(PATCH_MERGE_CMD),
            f"git tag -a {tag} -m {tag}",
            f"git push origin {tag}",
            f"gh run watch <cos-binary-release-run> --repo {args.repo} --exit-status",
            f"gh release view {tag} --repo {args.repo}",
        ],
    }
    if args.dry_run:
        print(json.dumps({"status": "dry-run", "publish": plan}, indent=2, sort_keys=True))
        return 0

    local_tag, remote_tag = tag_exists(root, tag)
    if local_tag or remote_tag:
        raise SystemExit(f"ERROR: tag {tag} already exists (local={local_tag} remote={remote_tag})")

    current = git(root, "branch", "--show-current").stdout.strip()
    if current in {"main", "master"}:
        git(root, "switch", "-c", branch, capture=False)
    elif current != branch:
        print(f"publish: staying on current branch {current}; requested branch is {branch}")

    run(["scripts/cos-patch-release", "validate"], cwd=root)
    git(root, "add", "-A", capture=False)
    if tracked_status(root):
        git(root, "commit", "-m", message, capture=False)
    else:
        print("publish: no tracked changes to commit")
    branch_now = git(root, "branch", "--show-current").stdout.strip()
    git(root, "push", "-u", "origin", branch_now, capture=False)
    run(PATCH_MERGE_CMD, cwd=root)
    git(root, "tag", "-a", tag, "-m", f"{tag} patch release", capture=False)
    git(root, "push", "origin", tag, capture=False)

    time.sleep(5)
    run(["gh", "run", "list", "--repo", args.repo, "--workflow", "cos-binary-release.yml", "--limit", "1"], cwd=root, check=False)
    latest = run(["gh", "run", "list", "--repo", args.repo, "--workflow", "cos-binary-release.yml", "--limit", "1", "--json", "databaseId"], cwd=root, capture=True, check=False)
    try:
        rows = json.loads(latest.stdout)
        if rows:
            run(["gh", "run", "watch", str(rows[0]["databaseId"]), "--repo", args.repo, "--interval", "10", "--exit-status"], cwd=root)
    except Exception:
        print("publish: unable to auto-watch release run; inspect GitHub Actions manually", file=sys.stderr)
    run(["gh", "release", "view", tag, "--repo", args.repo], cwd=root)
    print(f"patch-release-publish-ok version={bare} tag={tag}")
    return 0


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description="Prepare, validate, publish, and diagnose Cognitive OS patch releases.")
    parser.add_argument("--project-dir", help="Repository root. Defaults to git root.")
    sub = parser.add_subparsers(dest="command", required=True)

    p_prepare = sub.add_parser("prepare", help="Bump release files and lock dependencies.")
    p_prepare.add_argument("--version", required=True)
    p_prepare.add_argument("--title", default="Patch Release Primitive")
    p_prepare.add_argument("--dry-run", action="store_true")
    p_prepare.set_defaults(func=prepare)

    p_validate = sub.add_parser("validate", help="Run patch-release validation lane.")
    p_validate.add_argument("--print-commands", action="store_true")
    p_validate.set_defaults(func=validate)

    p_plan = sub.add_parser("plan", help="Print the complete patch release flow without mutating the repo.")
    p_plan.add_argument("--version", required=True)
    p_plan.add_argument("--title", default="Patch Release")
    p_plan.add_argument("--branch")
    p_plan.add_argument("--repo", default="Luum-Home/luum-cognitive-os")
    p_plan.set_defaults(func=release_flow_plan)

    p_publish = sub.add_parser("publish", help="Commit, land, tag, push, and watch release.")
    p_publish.add_argument("--version", required=True)
    p_publish.add_argument("--branch")
    p_publish.add_argument("--message")
    p_publish.add_argument("--repo", default="Luum-Home/luum-cognitive-os")
    p_publish.add_argument("--dry-run", action="store_true")
    p_publish.set_defaults(func=publish)

    p_doctor = sub.add_parser("doctor", help="Diagnose release hazards.")
    p_doctor.add_argument("--version")
    p_doctor.add_argument("--repo", default="Luum-Home/luum-cognitive-os")
    p_doctor.add_argument("--json", action="store_true")
    p_doctor.add_argument("--strict", action="store_true", help="Run strict release-contract diagnostics in addition to publish hazards.")
    p_doctor.add_argument("--contract-only", action="store_true", help="Check release contracts only; skip publish-time hazards such as tag availability, gh auth, and clean worktree.")
    p_doctor.add_argument("--allow-warnings", action="store_true")
    p_doctor.set_defaults(func=doctor)
    return parser


def main(argv: Sequence[str] | None = None) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)
    return int(args.func(args))


if __name__ == "__main__":
    raise SystemExit(main())
