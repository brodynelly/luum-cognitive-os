#!/usr/bin/env python3
from __future__ import annotations

import argparse
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
if str(ROOT) not in sys.path:
    sys.path.insert(0, str(ROOT))

from lib.external_tool_intelligence import render_markdown, render_radar, repo_root, write_json


def main() -> int:
    parser = argparse.ArgumentParser(description="Render effective external-tool radar from COS manifest and project overlay.")
    parser.add_argument("--repo", default=".")
    parser.add_argument("--manifest", default="manifests/external-tools-adoption.yaml")
    parser.add_argument("--overlay", default=None)
    parser.add_argument("--mode", choices=["os-only", "project-only", "combined"], default="combined")
    parser.add_argument("--json", action="store_true")
    parser.add_argument("--markdown", action="store_true")
    args = parser.parse_args()
    root = repo_root(Path(args.repo))
    manifest = root / args.manifest if not Path(args.manifest).is_absolute() else Path(args.manifest)
    overlay = None
    if args.overlay:
        overlay = root / args.overlay if not Path(args.overlay).is_absolute() else Path(args.overlay)
    else:
        default_overlay = root / ".cognitive-os" / "external-tools-overlay.yaml"
        overlay = default_overlay if default_overlay.exists() else None
    payload = render_radar(manifest, overlay, mode=args.mode)
    if args.markdown:
        print(render_markdown(payload), end="")
    else:
        print(write_json(payload), end="")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
