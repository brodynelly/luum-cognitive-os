#!/usr/bin/env python3
"""Regenerate ADR-281 product answer cards and routing index."""
from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
if str(ROOT) not in sys.path:
    sys.path.insert(0, str(ROOT))

from lib.product_answer import ProductAnswerError, refresh_answer_cards  # noqa: E402


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    group = parser.add_mutually_exclusive_group()
    group.add_argument("--question-id", help="Refresh one question id")
    group.add_argument("--all", action="store_true", help="Refresh all question ids")
    parser.add_argument("--project-dir", type=Path, default=ROOT)
    parser.add_argument("--question-bank", type=Path)
    parser.add_argument("--claim-evidence", type=Path)
    parser.add_argument("--cache-dir", type=Path, help="Override ADR-281 answer-card cache directory")
    parser.add_argument("--strict", action="store_true")
    parser.add_argument("--json", action="store_true")
    args = parser.parse_args()

    try:
        report = refresh_answer_cards(
            args.project_dir,
            question_id=None if args.all or args.question_id is None else args.question_id,
            question_bank_path=args.question_bank,
            claim_evidence_path=args.claim_evidence,
            cache_dir_override=args.cache_dir,
            strict=args.strict,
        )
    except ProductAnswerError as exc:
        report = {
            "schema_version": "product-answer-refresh-report/v1",
            "adr": "ADR-281",
            "status": "fail",
            "error": str(exc),
        }
        if args.json:
            print(json.dumps(report, indent=2, sort_keys=True))
        else:
            print(f"product-answer-refresh: fail: {exc}", file=sys.stderr)
        return 2

    if args.json:
        print(json.dumps(report, indent=2, sort_keys=True))
    else:
        print(f"product-answer-refresh: {report['status']} refreshed={report['refreshed_count']} index={report['index']}")
        for card in report["cards"]:
            print(f"- {card}")
    return 2 if report["status"] == "fail" else 0


if __name__ == "__main__":
    raise SystemExit(main())
