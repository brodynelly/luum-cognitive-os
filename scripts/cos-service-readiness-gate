#!/usr/bin/env python3
"""CLI for ADR-211 Service-Mode Readiness Gate."""
from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
if str(ROOT) not in sys.path:
    sys.path.insert(0, str(ROOT))

from lib.performance_ledger import repo_root  # noqa: E402
from lib.service_mode_readiness import build_readiness_report  # noqa: E402


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description="Aggregate service-mode readiness gates for Cognitive OS.")
    parser.add_argument("--project-dir", type=Path, default=repo_root())
    parser.add_argument("--json", action="store_true")
    return parser


def main() -> int:
    args = build_parser().parse_args()
    payload = build_readiness_report(args.project_dir)
    if args.json:
        print(json.dumps(payload, indent=2, sort_keys=True))
    else:
        print(f"service readiness: {payload['status']} green={payload['summary']['green']} yellow={payload['summary']['yellow']} red={payload['summary']['red']}")
        for gate in payload["gates"]:
            print(f"- {gate['status'].upper()} {gate['id']}: {gate['summary']}")
    return 2 if payload["status"] == "red" else 0


if __name__ == "__main__":
    raise SystemExit(main())
