#!/usr/bin/env python3
"""CLI for ADR-208 dependency adoption gate."""
from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
if str(ROOT) not in sys.path:
    sys.path.insert(0, str(ROOT))

from lib.dependency_adoption_gate import current_dependency_inventory, evaluate_staged, format_human, repo_root  # noqa: E402


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description="Require pre-adoption evidence for dependency manifest additions.")
    parser.add_argument("--project-dir", type=Path, default=repo_root())
    parser.add_argument("--staged", action="store_true", help="Evaluate staged dependency manifest additions")
    parser.add_argument("--audit", action="store_true", help="List current dependency manifests and evidence artifacts")
    parser.add_argument("--coverage-aware", action="store_true", help="Run dependency coverage triage alongside adoption inventory")
    parser.add_argument("--strict", action="store_true", help="With --coverage-aware, exit 2 when actionable coverage findings exist")
    parser.add_argument("--json", action="store_true")
    return parser


def main() -> int:
    args = build_parser().parse_args()
    if args.coverage_aware:
        from lib.dependency_coverage_audit import build_report
        from lib.dependency_tool_intake import build_triage_report, format_human as format_triage_human

        coverage = build_report(args.project_dir)
        payload = build_triage_report(coverage)
        if args.json:
            print(json.dumps(payload, indent=2, sort_keys=True))
        else:
            print(format_triage_human(payload), end="")
        actionable = payload.get("summary", {}).get("actionable", 0)
        return 2 if args.strict and actionable else 0

    if args.audit:
        payload = current_dependency_inventory(args.project_dir)
        if args.json:
            print(json.dumps(payload, indent=2, sort_keys=True))
        else:
            print(
                "dependency adoption inventory: "
                f"{payload['status']} manifests={payload['dependency_manifest_count']} "
                f"evidence={payload['adoption_evidence_count']}"
            )
        return 0 if payload["status"] == "ok" else 1
    result = evaluate_staged(args.project_dir)
    if args.json:
        print(json.dumps(result.to_dict(), indent=2, sort_keys=True))
    else:
        stream = sys.stderr if result.status == "block" else sys.stdout
        print(format_human(result), file=stream)
    return result.exit_code


if __name__ == "__main__":
    raise SystemExit(main())
