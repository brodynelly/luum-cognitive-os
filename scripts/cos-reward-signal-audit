#!/usr/bin/env python3
"""CLI audit for ADR-204 reward signal quality."""
from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
if str(ROOT) not in sys.path:
    sys.path.insert(0, str(ROOT))

from lib.reward_signal_quality import audit_stream, load_contract, repo_root, summarize  # noqa: E402


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description="Audit reward signal quality before ledger rollups.")
    parser.add_argument("--project-dir", type=Path, default=repo_root())
    parser.add_argument("--contract", type=Path, default=repo_root() / "manifests" / "reward-signal-contract.yaml")
    parser.add_argument("--stream", action="append", help="Stream id to audit; defaults to all manifest streams")
    parser.add_argument("--limit", type=int)
    parser.add_argument("--strict", action="store_true", help="Exit 2 if suspect/corrupt rows are present")
    parser.add_argument("--json", action="store_true")
    return parser


def main() -> int:
    args = build_parser().parse_args()
    contract = load_contract(args.contract)
    streams = args.stream or sorted((contract.get("streams", {}) or {}).keys())
    stream_reports = {}
    all_results = []
    for stream in streams:
        results = audit_stream(args.project_dir.resolve(), contract, stream, args.limit)
        stream_reports[stream] = {
            "summary": summarize(results),
            "quarantined": [result.to_dict() for result in results if not result.eligible_for_rollup][:20],
        }
        all_results.extend(results)
    summary = summarize(all_results)
    payload = {
        "schema_version": "reward-signal-audit/v1",
        "project_dir": str(args.project_dir.resolve()),
        "contract": str(args.contract),
        "summary": summary,
        "streams": stream_reports,
    }
    if args.json:
        print(json.dumps(payload, indent=2, sort_keys=True))
    else:
        print(
            "reward-signal audit: "
            f"valid={summary['valid']} suspect={summary['suspect']} corrupt={summary['corrupt']} "
            f"eligible={summary['eligible_for_rollup']}/{summary['total']}"
        )
    return 2 if args.strict and (summary["suspect"] or summary["corrupt"]) else 0


if __name__ == "__main__":
    raise SystemExit(main())
