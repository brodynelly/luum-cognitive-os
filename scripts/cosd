#!/usr/bin/env bash
# SCOPE: os-only
# PURPOSE: ADR-184 cosd daemon entrypoint plus legacy service status fallback.
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

case "${1:-status}" in
  start|stop|status|loop|process-once|submit-intent|serve|serve-unix)
    exec python3 "$SCRIPT_DIR/cos_daemon.py" "$@"
    ;;
  service-status)
    shift
    exec python3 "$SCRIPT_DIR/cos_service_control_plane.py" cosd status "$@"
    ;;
  *)
    exec python3 "$SCRIPT_DIR/cos_daemon.py" "$@"
    ;;
esac
