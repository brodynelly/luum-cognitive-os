#!/usr/bin/env bash
# SCOPE: both
# ROLE: headless-runtime
# CANONICAL: scripts/cos-headless-safe-mode
# @on-demand: Manage local headless safe mode / kill switch for task admission.
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [ -z "${PYTHON_BIN:-}" ]; then
  if [ -n "${PYTHON:-}" ]; then
    PYTHON_BIN="$PYTHON"
  elif [ -x "$SCRIPT_DIR/../.venv/bin/python" ]; then
    PYTHON_BIN="$SCRIPT_DIR/../.venv/bin/python"
  else
    PYTHON_BIN="python3"
  fi
fi
exec "$PYTHON_BIN" "$SCRIPT_DIR/cos_headless_safe_mode.py" "$@"
