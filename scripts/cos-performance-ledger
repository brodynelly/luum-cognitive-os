#!/usr/bin/env python3
"""Compile ADR-201 Performance Ledger from validated ADR-204 reward signals."""
from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
if str(ROOT) not in sys.path:
    sys.path.insert(0, str(ROOT))

from lib.performance_ledger import compile_ledger, repo_root  # noqa: E402


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description="Compile local Performance Ledger from validated reward signals.")
    parser.add_argument("--project-dir", type=Path, default=repo_root())
    parser.add_argument("--contract", type=Path)
    parser.add_argument("--sqlite-path", type=Path)
    parser.add_argument("--jsonl-path", type=Path)
    parser.add_argument("--latest-report-path", type=Path)
    parser.add_argument("--stream", action="append", help="Reward stream to ingest; defaults to all")
    parser.add_argument("--run-id")
    parser.add_argument("--limit", type=int)
    parser.add_argument("--no-write", action="store_true", help="Compile but do not write JSONL/latest report")
    parser.add_argument("--require-consumable", action="store_true", help="Exit 2 when any stream is blocked by consumption policy")
    parser.add_argument("--json", action="store_true")
    return parser


def main() -> int:
    args = build_parser().parse_args()
    payload = compile_ledger(
        args.project_dir,
        contract_path=args.contract,
        sqlite_path=args.sqlite_path,
        jsonl_path=args.jsonl_path,
        latest_report_path=args.latest_report_path,
        streams=args.stream,
        run_id=args.run_id,
        limit=args.limit,
        write=not args.no_write,
    )
    if args.json:
        print(json.dumps(payload, indent=2, sort_keys=True))
    else:
        summary = payload["summary"]
        print(
            "performance ledger: "
            f"valid={summary['valid']} suspect={summary['suspect']} corrupt={summary['corrupt']} "
            f"eligible={summary['eligible_for_rollup']}/{summary['total']} "
            f"sqlite={payload['sqlite_path']}"
        )
    if args.require_consumable and not payload["consumption_policy"]["can_consume_all"]:
        return 2
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
