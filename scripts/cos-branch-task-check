#!/usr/bin/env python3
from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT))

from lib.branch_task_policy import evaluate_branch_for_task  # noqa: E402


def main() -> int:
    parser = argparse.ArgumentParser(description="Check ADR-225 branch-per-task policy.")
    parser.add_argument("--project-dir", default=".")
    parser.add_argument("--task-id", required=True)
    parser.add_argument("--prefix", default="codex/task")
    parser.add_argument("--current")
    parser.add_argument("--json", action="store_true")
    parser.add_argument("--strict", action="store_true")
    args = parser.parse_args()
    verdict = evaluate_branch_for_task(args.project_dir, task_id=args.task_id, prefix=args.prefix, current=args.current)
    if args.json:
        print(json.dumps(verdict.to_dict(), sort_keys=True))
    else:
        print(f"{verdict.status}: current={verdict.current_branch} expected={verdict.expected_branch}")
    return 2 if args.strict and verdict.status == "BLOCK" else 0


if __name__ == "__main__":
    raise SystemExit(main())
