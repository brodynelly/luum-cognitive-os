#!/usr/bin/env bash
# SCOPE: os-only
# cos-agent-spawn-benchmark — ADR-303: sub-agent spawn cold-start benchmark.
#
# Measures the operator-side cost of "spawn a sub-agent": the SubagentStart
# hook chain's wall-clock latency and the token payload it injects.
#
# Usage:
#   bash scripts/cos-agent-spawn-benchmark [--json] [--markdown] [--output PATH]
#
# Exit codes:
#   0  — benchmark completed (even on SLO breach; tests gate on breach)
#   1  — internal error (Python module failure)
#
# This script is a thin wrapper around lib.agent_spawn_benchmark.

set -uo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
PROJECT_DIR="${COGNITIVE_OS_PROJECT_DIR:-${CLAUDE_PROJECT_DIR:-$SCRIPT_DIR}}"

EMIT_JSON=0
EMIT_MARKDOWN=0
OUTPUT_PATH=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --json) EMIT_JSON=1; shift ;;
    --markdown) EMIT_MARKDOWN=1; shift ;;
    --output) OUTPUT_PATH="$2"; shift 2 ;;
    --project-dir) PROJECT_DIR="$2"; shift 2 ;;
    -h|--help)
      sed -n '2,16p' "$0"
      exit 0
      ;;
    *) echo "Unknown arg: $1" >&2; exit 2 ;;
  esac
done

# Default: emit markdown if no explicit output flag is given
if [[ $EMIT_JSON -eq 0 && $EMIT_MARKDOWN -eq 0 ]]; then
  EMIT_MARKDOWN=1
fi

PY="${PYTHON:-python3}"
if [[ -x "$PROJECT_DIR/.venv/bin/python" ]]; then
  PY="$PROJECT_DIR/.venv/bin/python"
fi

cd "$PROJECT_DIR"

"$PY" - "$PROJECT_DIR" "$OUTPUT_PATH" "$EMIT_JSON" "$EMIT_MARKDOWN" <<'PYEOF'
import json
import sys
from dataclasses import asdict
from pathlib import Path

sys.path.insert(0, str(Path(sys.argv[1])))
from lib.agent_spawn_benchmark import (  # noqa: E402
    build_record,
    append_jsonl,
    render_markdown,
    default_output_path,
    default_settings_path,
)

project_dir = Path(sys.argv[1]).resolve()
output_override = sys.argv[2]
emit_json = sys.argv[3] == "1"
emit_md = sys.argv[4] == "1"

settings = default_settings_path(project_dir)
record = build_record(project_dir, settings)

output_path = Path(output_override) if output_override else default_output_path(project_dir)
append_jsonl(record, output_path)

if emit_md:
    print(render_markdown(record))
if emit_json:
    print(json.dumps(asdict(record), indent=2))

# Always print where the record landed (one line, parsable)
print(f"\nRecord appended to: {output_path}", file=sys.stderr)
PYEOF

exit $?
