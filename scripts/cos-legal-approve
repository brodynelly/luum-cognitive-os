#!/usr/bin/env python3
"""cos-legal-approve — Mark Annex F as reviewed-by-legal with counsel evidence.

ADR-270 primitive #5. Operations:
  1. Validate memo file exists.
  2. Validate ADR exists and is Accepted.
  3. Compute SHA-256 of memo.
  4. Update Annex F frontmatter.
  5. Append entry to manifests/legal-review-ledger.yaml.
"""
from __future__ import annotations

import argparse
import glob
import hashlib
import re
import sys
from datetime import datetime, timezone
from pathlib import Path

try:
    import yaml
except ImportError:  # pragma: no cover
    print("ERROR: PyYAML is required (`pip install PyYAML`)", file=sys.stderr)
    sys.exit(2)

ROOT = Path(__file__).resolve().parents[1]
LEDGER_PATH = ROOT / "manifests" / "legal-review-ledger.yaml"
VALID_DECISIONS = {"approved", "approved-with-conditions", "rejected"}


def sha256_of(path: Path) -> str:
    h = hashlib.sha256()
    with path.open("rb") as f:
        for chunk in iter(lambda: f.read(65536), b""):
            h.update(chunk)
    return h.hexdigest()


def find_adr_path(adr_ref: str) -> Path | None:
    """Find an ADR file by reference. When multiple ADRs share a number
    (e.g. one Proposed, one Accepted), prefer the Accepted one."""
    num = adr_ref.replace("ADR-", "")
    matches = [Path(p) for p in sorted(glob.glob(str(ROOT / f"docs/02-Decisions/adrs/ADR-{num}-*.md")))]
    if not matches:
        return None
    # Prefer Accepted; fall back to first match.
    for m in matches:
        if adr_is_accepted(m):
            return m
    return matches[0]


def adr_is_accepted(adr_path: Path) -> bool:
    """Read frontmatter and check status."""
    text = adr_path.read_text(encoding="utf-8")
    m = re.match(r"^---\n(.*?)\n---\n", text, re.DOTALL)
    if not m:
        return False
    try:
        fm = yaml.safe_load(m.group(1)) or {}
    except yaml.YAMLError:
        return False
    return str(fm.get("status", "")).lower() == "accepted"


def update_annex_f_frontmatter(annex_path: Path, updates: dict[str, str]) -> None:
    text = annex_path.read_text(encoding="utf-8")
    m = re.match(r"^---\n(.*?)\n---\n", text, re.DOTALL)
    if not m:
        raise SystemExit(f"Annex F has no YAML frontmatter: {annex_path}")
    fm_block = m.group(1)
    fm = yaml.safe_load(fm_block) or {}
    fm.update(updates)
    new_fm = yaml.safe_dump(fm, default_flow_style=False, sort_keys=False).rstrip()
    new_text = f"---\n{new_fm}\n---\n{text[m.end():]}"
    annex_path.write_text(new_text, encoding="utf-8")


def append_ledger_entry(tool: str, entry: dict) -> None:
    if not LEDGER_PATH.exists():
        raise SystemExit(f"Ledger missing: {LEDGER_PATH}")
    text = LEDGER_PATH.read_text(encoding="utf-8")
    data = yaml.safe_load(text) or {}
    entries = data.get("entries", []) or []

    # Find an existing pending entry for this tool — fill it in rather than
    # appending a duplicate. If not found, append fresh.
    target_idx = -1
    for i, e in enumerate(entries):
        if e.get("tool") == tool and str(e.get("decision", "")).lower() == "pending":
            target_idx = i
            break

    if target_idx >= 0:
        entries[target_idx].update(entry)
    else:
        entries.append(entry)

    data["entries"] = entries
    # Preserve header comment by re-serializing carefully.
    new_yaml = yaml.safe_dump(data, default_flow_style=False, sort_keys=False)
    LEDGER_PATH.write_text(new_yaml, encoding="utf-8")


def derive_tool_slug(annex_path: Path) -> str:
    """Best-effort tool slug from annex filename."""
    name = annex_path.stem
    name = re.sub(r"-annex-f.*$", "", name)
    name = re.sub(r"^annex-f-?", "", name)
    return name.lower() or "unknown"


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(description="Mark Annex F reviewed-by-legal (ADR-270 #5)")
    parser.add_argument("--adr", required=True)
    parser.add_argument("--annex-f", required=True)
    parser.add_argument("--counsel", required=True, help="Name, Firm")
    parser.add_argument("--memo", required=True)
    parser.add_argument("--decision", required=True, choices=sorted(VALID_DECISIONS))
    parser.add_argument("--conditions", default="")
    parser.add_argument("--date", default=datetime.now(timezone.utc).strftime("%Y-%m-%d"))
    parser.add_argument("--tool", default="", help="explicit tool slug (else derived from annex filename)")
    args = parser.parse_args(argv)

    # 1. Validate memo exists
    memo_path = Path(args.memo)
    if not memo_path.is_absolute():
        memo_path = (ROOT / memo_path).resolve()
    if not memo_path.exists():
        print(f"ERROR: memo file not found: {memo_path}", file=sys.stderr)
        return 1

    # 2. Validate ADR
    adr_path = find_adr_path(args.adr)
    if not adr_path:
        print(f"ERROR: ADR not found: {args.adr}", file=sys.stderr)
        return 1
    if not adr_is_accepted(adr_path):
        print(f"ERROR: ADR is not Accepted: {adr_path}", file=sys.stderr)
        return 1

    # 3. Validate decision/conditions consistency
    if args.decision == "approved-with-conditions" and not args.conditions:
        print("ERROR: --conditions is required when decision=approved-with-conditions", file=sys.stderr)
        return 1

    # 4. Resolve annex path
    annex_path = Path(args.annex_f)
    if not annex_path.is_absolute():
        annex_path = (ROOT / annex_path).resolve()
    if not annex_path.exists():
        print(f"ERROR: Annex F not found: {annex_path}", file=sys.stderr)
        return 1

    # 5. Compute SHA-256
    memo_sha = sha256_of(memo_path)

    # 6. Update annex frontmatter
    update_annex_f_frontmatter(
        annex_path,
        {
            "reviewed-by-legal": "yes",
            "legal-counsel": args.counsel,
            "legal-decision": args.decision,
            "legal-memo-sha256": memo_sha,
            "legal-memo-path": str(memo_path.relative_to(ROOT)) if str(memo_path).startswith(str(ROOT)) else str(memo_path),
            "legal-review-date": args.date,
        },
    )

    # 7. Append/update ledger
    tool = args.tool or derive_tool_slug(annex_path)
    entry = {
        "tool": tool,
        "adr_ref": args.adr,
        "counsel": args.counsel,
        "memo_path": str(memo_path.relative_to(ROOT)) if str(memo_path).startswith(str(ROOT)) else str(memo_path),
        "memo_sha256": memo_sha,
        "decision": args.decision,
        "conditions": args.conditions or None,
        "review_date": args.date,
        "reviewed_at": datetime.now(timezone.utc).isoformat(),
        "annex_f_path": str(annex_path.relative_to(ROOT)) if str(annex_path).startswith(str(ROOT)) else str(annex_path),
    }
    append_ledger_entry(tool, entry)

    print(f"OK: marked {annex_path.name} reviewed-by-legal: yes")
    print(f"     decision = {args.decision}")
    print(f"     memo_sha256 = {memo_sha}")
    print(f"     ledger entry recorded for tool '{tool}'")
    return 0


if __name__ == "__main__":
    sys.exit(main())
