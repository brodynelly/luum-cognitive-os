#!/bin/bash
# COS pre-commit hook — content policy + Python validation
set -euo pipefail

# Shared error counter (used by Gate 2 and Gate 3e)
errors=0

# --- Gate 1: Block project-specific terms ---
BLOCKED="n""1u|N""1u|N""1U|<consumer-codename-b>|<consumer-codename-c>|alta-tienda"
VIOLATIONS=$(git diff --cached --name-only | grep -v ".githooks/" | grep -v "^tests/" | xargs grep -l -E "$BLOCKED" 2>/dev/null | grep -v ".git/" | grep -v "docs/business/" || true)
if [ -n "$VIOLATIONS" ]; then
  echo "BLOCKED: Project-specific terms found. Use generic names."
  echo "$VIOLATIONS"
  exit 1
fi

# --- Gate 2: Python syntax + lint (ruff or py_compile) ---
staged_py=$(git diff --cached --name-only --diff-filter=ACM -- '*.py' || true)
if [ -n "$staged_py" ]; then
  COS_ROOT="$(git rev-parse --show-toplevel)"

  if command -v ruff &>/dev/null; then
    # ruff: catches syntax errors (E9) and undefined names (F821)
    while IFS= read -r file; do
      [ -z "$file" ] && continue
      [ ! -f "$file" ] && continue
      if ! ruff check --select E9,F821 --no-fix --quiet "$file" 2>/dev/null; then
        ruff check --select E9,F821 --no-fix "$file" 2>&1 || true
        errors=$((errors + 1))
      fi
    done <<< "$staged_py"
  fi

  # For lib/ modules: verify actual import works
  staged_lib=$(echo "$staged_py" | grep "^lib/[^/]*\.py$" || true)
  if [ -n "$staged_lib" ]; then
    while IFS= read -r file; do
      [ -z "$file" ] && continue
      [ ! -f "$file" ] && continue
      module=$(echo "$file" | sed 's|/|.|g' | sed 's|\.py$||')
      if ! (cd "$COS_ROOT" && python3 -c "import $module" 2>/dev/null); then
        echo "IMPORT ERROR: $file — 'python3 -c \"import $module\"' fails"
        (cd "$COS_ROOT" && python3 -c "import $module" 2>&1) || true
        errors=$((errors + 1))
      fi
    done <<< "$staged_lib"
  fi

  if [ "$errors" -gt 0 ]; then
    echo ""
    echo "Pre-commit: $errors Python file(s) have errors. Fix before committing."
    exit 1
  fi
fi

# --- Gate 3: Consistency checks (advisory — warn, don't block) ---
COS_ROOT="${COS_ROOT:-$(git rev-parse --show-toplevel)}"
warnings=0

# Gate 3a. New hook files MUST be registered in apply-efficiency-profile.sh
staged_hooks=$(git diff --cached --name-only --diff-filter=A -- 'hooks/*.sh' || true)
if [ -n "$staged_hooks" ]; then
  while IFS= read -r hook; do
    [ -z "$hook" ] && continue
    hookname=$(basename "$hook")
    # Skip _lib/ internal helpers (not meant to be registered)
    case "$hookname" in _*) continue ;; esac
    if ! grep -q "$hookname" "$COS_ROOT/scripts/apply-efficiency-profile.sh" 2>/dev/null; then
      echo "BLOCKED: New hook $hookname is NOT registered in apply-efficiency-profile.sh — it will never fire"
      echo "  Add it to the appropriate profile (lean/standard/full) in scripts/apply-efficiency-profile.sh"
      echo "  Also add it to scripts/set-security-profile.sh (minimal/standard/paranoid)"
      exit 1
    fi
    if ! grep -q "$hookname" "$COS_ROOT/scripts/set-security-profile.sh" 2>/dev/null; then
      echo "BLOCKED: New hook $hookname is NOT registered in set-security-profile.sh"
      echo "  Add it to the appropriate profile (minimal/standard/paranoid)"
      exit 1
    fi
  done <<< "$staged_hooks"
fi

# Gate 3b. New lib/ files MUST NOT break symlink architecture
staged_lib_new=$(git diff --cached --name-only --diff-filter=A -- 'lib/*.py' || true)
if [ -n "$staged_lib_new" ]; then
  while IFS= read -r libfile; do
    [ -z "$libfile" ] && continue
    # Check if there's a corresponding file in packages/ (should be symlinked, not duplicated)
    basename_py=$(basename "$libfile")
    pkg_match=$(find "$COS_ROOT/packages" -name "$basename_py" -not -path "*/__pycache__/*" 2>/dev/null | head -1)
    if [ -n "$pkg_match" ] && [ ! -L "$COS_ROOT/$libfile" ]; then
      echo "WARNING: $libfile exists in packages/ but is NOT a symlink"
      echo "  lib/ files should be symlinks to packages/*/lib/. Check architecture."
      warnings=$((warnings + 1))
    fi
  done <<< "$staged_lib_new"
fi

# Gate 3c. New skills MUST have SKILL.md
staged_skill_dirs=$(git diff --cached --name-only --diff-filter=A -- '.cognitive-os/skills/*' || true)
if [ -n "$staged_skill_dirs" ]; then
  # Extract unique skill directory names
  skill_dirs=$(echo "$staged_skill_dirs" | grep -oP '\.cognitive-os/skills/[^/]+' | sort -u || true)
  while IFS= read -r skilldir; do
    [ -z "$skilldir" ] && continue
    if [ ! -f "$COS_ROOT/$skilldir/SKILL.md" ]; then
      echo "WARNING: Skill directory $skilldir has no SKILL.md"
      warnings=$((warnings + 1))
    fi
  done <<< "$skill_dirs"
fi

# Gate 3d. settings.json should not be edited directly (use apply-efficiency-profile.sh)
staged_settings=$(git diff --cached --name-only -- '.claude/settings.json' || true)
if [ -n "$staged_settings" ]; then
  # Check if apply-efficiency-profile.sh was also modified (legitimate regeneration)
  staged_profile=$(git diff --cached --name-only -- 'scripts/apply-efficiency-profile.sh' || true)
  if [ -z "$staged_profile" ]; then
    echo "WARNING: .claude/settings.json modified directly without updating scripts/apply-efficiency-profile.sh"
    echo "  Hooks in settings.json are regenerated by: bash scripts/apply-efficiency-profile.sh"
    echo "  Add your hooks to the script first, then regenerate."
    warnings=$((warnings + 1))
  fi
fi

# Gate 3e. Workflow YAMLs must parse (advisory — warn only)
staged_workflows=$(git diff --cached --name-only --diff-filter=ACM -- '.cognitive-os/workflows/*.yaml' '.cognitive-os/workflows/*.yml' || true)
if [ -n "$staged_workflows" ]; then
  while IFS= read -r wf; do
    [ -z "$wf" ] && continue
    [ ! -f "$wf" ] && continue
    if ! python3 -c "import yaml; yaml.safe_load(open('$wf'))" 2>/dev/null; then
      echo "WARNING: Workflow $wf has invalid YAML"
      python3 -c "import yaml; yaml.safe_load(open('$wf'))" 2>&1 || true
      warnings=$((warnings + 1))
    fi
  done <<< "$staged_workflows"
fi

if [ "$warnings" -gt 0 ]; then
  echo ""
  echo "Pre-commit: $warnings consistency warning(s). Review above before pushing."
fi
