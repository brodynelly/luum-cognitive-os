# =============================================================================
# Cognitive OS — .gitignore
# =============================================================================

# ── Cognitive OS runtime (generated during sessions, never committed) ────────
.cognitive-os/
dynamic-tools/
sessions/
transcripts/
checkpoints/*.json
!checkpoints/.gitkeep
tasks/active-tasks.json
tasks/.active-tasks.lock
!tasks/.gitkeep

# Metrics (append-only files generated by hooks)
metrics/*.jsonl
!metrics/.gitkeep

# Auto-generated skills (session-scoped)
skills/auto-generated/

# Runtime state
.last-sync
rate-limit-state.json

# ── Compiled Go binaries + SQLite scratch (build artifacts) ──────────────────
/cos-dispatch
*.exe
*.test
*.db
*.db-journal

# ── Plugin runtime data ─────────────────────────────────────────────────────
.claude/plugins/.cognitive-os/

# ── Harness-installed skills (symlinks generated by self-install.sh) ─────────
# Populated by `bash hooks/self-install.sh` from skills/ — same pattern as
# .cognitive-os/skills/. Not committed; installer is source of truth.
.claude/skills/

# ── Claude Code local settings (machine-specific, not shared) ───────────────
.claude/settings.local.json

# ── Environment & secrets ───────────────────────────────────────────────────
.env
.env.local
.env.*
!.env.example
*.pem
*.key
infra/seaweedfs/s3.json

# ── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.venv/
*.egg-info/
dist/
build/
.pytest_cache/
.ruff_cache/
htmlcov/
.coverage
.coverage.*
.report.json

# ── Go ──────────────────────────────────────────────────────────────────────
cmd/cos/cos
cmd/cos-test/cos-test

# ── Node.js ─────────────────────────────────────────────────────────────────
node_modules/

# ── Tool caches ─────────────────────────────────────────────────────────────
.promptfoo/
.devbox/

# ── Reference repos (cloned for study, not part of Cognitive OS) ────────────
reference/

# ── OS & editor ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.bak
*.log
*.swp
*~
mutants/
conftest.py
cos_mutation.sqlite
.claude/worktrees/

# Cognitive OS local memory exports (may contain private absolute paths)
.engram/exports/*.jsonl
