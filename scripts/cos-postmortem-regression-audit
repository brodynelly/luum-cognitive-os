#!/usr/bin/env python3
# SCOPE: os-only
"""Manifest-driven read-only regression audit for postmortem ADRs.

The script is a generic check engine. ADR mappings, paths, forbidden patterns,
required artifacts, and external-tool adapter declarations live in
``manifests/postmortem-regression-audit.yaml``.
"""
from __future__ import annotations

import argparse
import json
import re
import subprocess
from dataclasses import dataclass
from pathlib import Path
from typing import Any, Iterable

import yaml

SCHEMA_VERSION = "postmortem-regression-audit/v1"
DEFAULT_MANIFEST = Path("manifests/postmortem-regression-audit.yaml")


@dataclass
class Finding:
    severity: str
    code: str
    adr: str
    message: str
    path: str | None = None
    details: dict[str, Any] | None = None

    def to_dict(self) -> dict[str, Any]:
        out: dict[str, Any] = {
            "severity": self.severity,
            "code": self.code,
            "adr": self.adr,
            "message": self.message,
        }
        if self.path:
            out["path"] = self.path
        if self.details:
            out["details"] = self.details
        return out


def read(path: Path) -> str:
    try:
        return path.read_text(encoding="utf-8", errors="replace")
    except FileNotFoundError:
        return ""


def load_yaml(path: Path) -> dict[str, Any]:
    if not path.exists():
        return {}
    return yaml.safe_load(path.read_text(encoding="utf-8")) or {}


def rel(path: Path, root: Path) -> str:
    try:
        return path.relative_to(root).as_posix()
    except ValueError:
        return str(path)


def git_root(start: Path) -> Path:
    proc = subprocess.run(
        ["git", "-C", str(start), "rev-parse", "--show-toplevel"],
        text=True,
        capture_output=True,
        check=False,
        timeout=60,
    )
    if proc.returncode == 0 and proc.stdout.strip():
        return Path(proc.stdout.strip()).resolve()
    return start.resolve()


def iter_files(root: Path, scopes: Iterable[str], suffixes: tuple[str, ...]) -> Iterable[Path]:
    for scope in scopes:
        path = root / scope
        if path.is_file():
            if path.suffix in suffixes:
                yield path
            continue
        if not path.exists():
            continue
        for candidate in path.rglob("*"):
            if candidate.is_file() and candidate.suffix in suffixes and ".git" not in candidate.parts:
                yield candidate


def finding(check: dict[str, Any], path: str | None = None, details: dict[str, Any] | None = None) -> Finding:
    return Finding(
        severity=str(check.get("severity", "block")),
        code=str(check.get("id", "unknown-check")),
        adr=str(check.get("adr", "UNKNOWN")),
        message=str(check.get("message", "Postmortem regression audit finding.")),
        path=path,
        details=details,
    )


def check_required_paths(root: Path, check: dict[str, Any]) -> list[Finding]:
    return [finding(check, path) for path in check.get("paths", []) or [] if not (root / str(path)).exists()]


def check_required_tokens(root: Path, check: dict[str, Any]) -> list[Finding]:
    combined = "\n".join(read(root / str(path)) for path in check.get("files", []) or [])
    missing = [str(token) for token in check.get("tokens", []) or [] if str(token) not in combined]
    if missing:
        return [finding(check, str((check.get("files") or [None])[0]), {"missing_tokens": missing})]
    return []


def check_forbidden_pattern(root: Path, check: dict[str, Any]) -> list[Finding]:
    pattern = re.compile(str(check.get("pattern", "a^")), re.I | re.M)
    suffixes = tuple(str(s) for s in (check.get("suffixes") or [".py", ".sh", ".md"]))
    allow = {str(path) for path in check.get("allow_paths", []) or []}
    out: list[Finding] = []
    for path in iter_files(root, [str(s) for s in check.get("scope", []) or []], suffixes):
        r = rel(path, root)
        if r in allow:
            continue
        if pattern.search(read(path)):
            out.append(finding(check, r))
    return out


def check_forbidden_line_pair(root: Path, check: dict[str, Any]) -> list[Finding]:
    line_pattern = re.compile(str(check.get("line_pattern", "a^")), re.I)
    same_line = re.compile(str(check.get("same_line_pattern", "a^")), re.I)
    suffixes = tuple(str(s) for s in (check.get("suffixes") or [".py"]))
    out: list[Finding] = []
    for path in iter_files(root, [str(s) for s in check.get("scope", []) or []], suffixes):
        for lineno, line in enumerate(read(path).splitlines(), start=1):
            if line_pattern.search(line) and same_line.search(line):
                out.append(finding(check, rel(path, root), {"line": lineno}))
    return out


def check_external_tools(manifest: dict[str, Any]) -> list[Finding]:
    required = {
        "tool",
        "owner",
        "license_spdx",
        "adapter",
        "allowed_callers",
        "failure_policy",
        "recursion_boundary",
        "input_sensitivity",
        "output_sanitization",
    }
    out: list[Finding] = []
    for tool in manifest.get("external_tools", []) or []:
        missing = sorted(field for field in required if not tool.get(field))
        if missing:
            out.append(
                Finding(
                    "block",
                    "external-tool-adapter-contract-incomplete",
                    "ADR-247",
                    "External tool adapter is missing required contract fields.",
                    str(tool.get("tool", "unknown")),
                    {"missing": missing},
                )
            )
    return out


CHECKERS = {
    "required_paths": check_required_paths,
    "required_tokens": check_required_tokens,
    "forbidden_pattern": check_forbidden_pattern,
    "forbidden_line_pair": check_forbidden_line_pair,
}


def audit(root: Path, manifest_path: Path) -> dict[str, Any]:
    manifest = load_yaml(manifest_path)
    findings: list[Finding] = []
    for check in manifest.get("checks", []) or []:
        checker = CHECKERS.get(str(check.get("type", "")))
        if not checker:
            findings.append(Finding("block", "unknown-check-type", str(check.get("adr", "UNKNOWN")), "Unknown postmortem regression audit check type.", details={"check": check}))
            continue
        findings.extend(checker(root, check))
    findings.extend(check_external_tools(manifest))
    block = sum(1 for f in findings if f.severity == "block")
    warn = sum(1 for f in findings if f.severity == "warn")
    return {
        "schema_version": SCHEMA_VERSION,
        "status": "block" if block else "warn" if warn else "pass",
        "repo": str(root),
        "manifest": str(manifest_path),
        "summary": {"block": block, "warn": warn, "findings": len(findings)},
        "findings": [f.to_dict() for f in findings],
        "policy": "Read-only manifest-driven detector for postmortem ADR bug classes; do not repair primitives before detection.",
    }


def main() -> int:
    parser = argparse.ArgumentParser(description="Audit postmortem ADR regression classes without mutating primitives.")
    parser.add_argument("--project-dir", type=Path, default=Path.cwd())
    parser.add_argument("--manifest", type=Path, default=None)
    parser.add_argument("--json", action="store_true")
    parser.add_argument("--strict", action="store_true", help="Treat warnings as failures.")
    args = parser.parse_args()
    root = git_root(args.project_dir)
    manifest = args.manifest or (root / DEFAULT_MANIFEST)
    report = audit(root, manifest)
    if args.json:
        print(json.dumps(report, indent=2, sort_keys=True))
    else:
        print(f"postmortem regression audit: {report['status']}")
        for item in report["findings"]:
            print(f"[{item['severity']}] {item['adr']} {item['code']}: {item['message']}")
    if report["summary"]["block"]:
        return 1
    if args.strict and report["summary"]["warn"]:
        return 1
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
