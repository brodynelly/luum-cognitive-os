#!/usr/bin/env python3
"""CLI for ADR-208 imported pattern closure audit."""
from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
if str(ROOT) not in sys.path:
    sys.path.insert(0, str(ROOT))

from lib.imported_pattern_closure import audit  # noqa: E402


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--manifest", type=Path, default=ROOT / "manifests" / "imported-pattern-closures.yaml")
    parser.add_argument("--json", action="store_true")
    args = parser.parse_args()
    report = audit(args.manifest)
    if args.json:
        print(json.dumps(report, indent=2, sort_keys=True))
    else:
        print(f"imported-pattern-closure-audit: {report['status']} closures={report['closure_count']} blocks={report['block_count']}")
        for finding in report["findings"][:20]:
            print(f"- [{finding['severity']}] {finding['id']}: missing {', '.join(finding['missing_fields'])}")
    return 2 if report["status"] == "fail" else 0


if __name__ == "__main__":
    raise SystemExit(main())

