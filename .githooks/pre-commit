#!/bin/bash
# COS pre-commit hook — content policy + Python validation
set -euo pipefail

# Shared error counter (used by Gate 2 and Gate 3e)
errors=0

# --- Gate 1: Block project-specific terms ---
#
# The list of blocked terms lives OUTSIDE the hook source so it is not
# itself committed to git. Operator places one literal pattern per line
# at .cognitive-os/private/blocked-strings.txt (path is gitignored).
# If the file is absent, Gate 1 is a no-op.
#
# Template + setup instructions: templates/blocked-strings.example.txt
COS_ROOT_FOR_GATE1="${COS_ROOT:-$(git rev-parse --show-toplevel)}"
BLOCKED_STRINGS_FILE="${COS_ROOT_FOR_GATE1}/.cognitive-os/private/blocked-strings.txt"
BLOCKED_STRINGS_OVERRIDE="${COS_BLOCKED_STRINGS_FILE:-}"
if [ -n "$BLOCKED_STRINGS_OVERRIDE" ] && [ -f "$BLOCKED_STRINGS_OVERRIDE" ]; then
  BLOCKED_STRINGS_FILE="$BLOCKED_STRINGS_OVERRIDE"
fi
if [ -f "$BLOCKED_STRINGS_FILE" ]; then
  # Read non-comment, non-empty lines as literal patterns.
  BLOCKED_PATTERN_FILE="$(mktemp -t cos-gate1.XXXXXX)"
  trap 'rm -f "$BLOCKED_PATTERN_FILE"' EXIT
  grep -vE '^[[:space:]]*(#|$)' "$BLOCKED_STRINGS_FILE" > "$BLOCKED_PATTERN_FILE" || true
  if [ -s "$BLOCKED_PATTERN_FILE" ]; then
    VIOLATIONS=""
    while IFS= read -r staged_path; do
      [ -z "$staged_path" ] && continue
      case "$staged_path" in
        .githooks/*|tests/*|.engram/exports/*|docs/architecture/POST-MORTEM*|docs/business/*|templates/blocked-strings.example.txt)
          continue
          ;;
      esac
      if git show ":$staged_path" 2>/dev/null | grep -qFf "$BLOCKED_PATTERN_FILE"; then
        VIOLATIONS="${VIOLATIONS}${staged_path}"$'\n'
      fi
    done < <(
      git diff --cached --raw -M -C --diff-filter=ACM 2>/dev/null \
        | awk '$4 != "160000" { n = split($0, parts, "\t"); if (n >= 2 && parts[n] != "") print parts[n] }'
    )
    VIOLATIONS=$(printf '%s' "$VIOLATIONS" | grep -v '^$' || true)
    if [ -n "$VIOLATIONS" ]; then
      echo "BLOCKED: Gate 1 — staged file(s) contain a pattern from $BLOCKED_STRINGS_FILE." >&2
      echo "$VIOLATIONS" >&2
      echo "" >&2
      echo "  Edit the file or move the content to a path Gate 1 ignores" >&2
      echo "  (.githooks/, tests/, .engram/exports/, docs/architecture/POST-MORTEM*, docs/business/)." >&2
      echo "  Template + setup: templates/blocked-strings.example.txt" >&2
      exit 1
    fi
  fi
fi

# --- Gate 1b: Block developer-specific absolute home paths ---
COS_ROOT="${COS_ROOT:-$(git rev-parse --show-toplevel)}"
if [ -f "$COS_ROOT/scripts/check_absolute_paths.py" ]; then
  if ! python3 "$COS_ROOT/scripts/check_absolute_paths.py" --root "$COS_ROOT" --staged; then
    exit 1
  fi
fi

# --- Gate 1d: Block AI-provider-looking invented author/contact identities ---
if [ -x "$COS_ROOT/scripts/ai-provider-identity-guard" ]; then
  if ! "$COS_ROOT/scripts/ai-provider-identity-guard" --project-dir "$COS_ROOT" --staged; then
    exit 1
  fi
fi

# --- Gate 1c: Dependency adoption evidence (ADR-208) ---
if [ "${COS_ALLOW_DEP_ADOPTION_BYPASS:-0}" = "1" ]; then
  echo "WARNING: COS_ALLOW_DEP_ADOPTION_BYPASS=1 skips dependency adoption gate"
elif [ -x "$COS_ROOT/scripts/cos-dependency-adoption-gate" ]; then
  if ! "$COS_ROOT/scripts/cos-dependency-adoption-gate" --project-dir "$COS_ROOT" --staged; then
    exit 1
  fi
fi

# --- Gate 2: Python syntax + lint (ruff or py_compile) ---
staged_py=$(git diff --cached --name-only --diff-filter=ACM -- '*.py' || true)
if [ -n "$staged_py" ]; then
  COS_ROOT="$(git rev-parse --show-toplevel)"

  if command -v ruff &>/dev/null; then
    # ruff: catches syntax errors (E9), undefined imports (F401), redefinitions (F811),
    # undefined names (F821), unused variables (F841).
    # F401 added 2026-04-27: catches `from lib.nonexistent import x` — the exact
    # anti-pattern that caused Cause 3 of the 33-fake-criticals bug (ADR-069 §5 fix).
    while IFS= read -r file; do
      [ -z "$file" ] && continue
      [ ! -f "$file" ] && continue
      if ! ruff check --select E9,F401,F811,F821,F841 --no-fix --quiet "$file" 2>/dev/null; then
        ruff check --select E9,F401,F811,F821,F841 --no-fix "$file" 2>&1 || true
        errors=$((errors + 1))
      fi
    done <<< "$staged_py"
  fi

  # For lib/ modules: verify actual import works
  staged_lib=$(echo "$staged_py" | grep "^lib/[^/]*\.py$" || true)
  if [ -n "$staged_lib" ]; then
    while IFS= read -r file; do
      [ -z "$file" ] && continue
      [ ! -f "$file" ] && continue
      module=$(echo "$file" | sed 's|/|.|g' | sed 's|\.py$||')
      if ! (cd "$COS_ROOT" && python3 -c "import $module" 2>/dev/null); then
        echo "IMPORT ERROR: $file — 'python3 -c \"import $module\"' fails"
        (cd "$COS_ROOT" && python3 -c "import $module" 2>&1) || true
        errors=$((errors + 1))
      fi
    done <<< "$staged_lib"
  fi

  if [ "$errors" -gt 0 ]; then
    echo ""
    echo "Pre-commit: $errors Python file(s) have errors. Fix before committing."
    exit 1
  fi
fi

# --- Gate 3: Consistency checks (advisory — warn, don't block) ---
COS_ROOT="${COS_ROOT:-$(git rev-parse --show-toplevel)}"
warnings=0

# Gate 3a. New hook files MUST be registered in apply-efficiency-profile.sh
staged_hooks=$(git diff --cached --name-only --diff-filter=A -- 'hooks/*.sh' || true)
if [ -n "$staged_hooks" ]; then
  while IFS= read -r hook; do
    [ -z "$hook" ] && continue
    hookname=$(basename "$hook")
    # Skip _lib/ internal helpers (not meant to be registered)
    case "$hookname" in _*) continue ;; esac
    case "$hook" in hooks/_lib/*) continue ;; esac
    if ! grep -q "$hookname" "$COS_ROOT/scripts/apply-efficiency-profile.sh" 2>/dev/null; then
      echo "BLOCKED: New hook $hookname is NOT registered in apply-efficiency-profile.sh — it will never fire"
      echo "  Add it to the appropriate profile (lean/standard/full) in scripts/apply-efficiency-profile.sh"
      echo "  Also add it to templates/security-profiles/*.json (minimal/standard/paranoid)"
      exit 1
    fi
    profile_sources=()
    if [ -d "$COS_ROOT/templates/security-profiles" ]; then
      profile_sources+=("$COS_ROOT"/templates/security-profiles/*.json)
    fi
    if [ "${#profile_sources[@]}" -eq 0 ] || [ ! -e "${profile_sources[0]}" ]; then
      profile_sources+=("$COS_ROOT"/.cognitive-os/plans/features/hook-architecture-v2-settings*.json)
    fi
    if ! grep -q "$hookname" "${profile_sources[@]}" 2>/dev/null; then
      echo "BLOCKED: New hook $hookname is NOT registered in security profile JSON"
      echo "  Add it to templates/security-profiles/*.json (minimal/standard/paranoid)"
      exit 1
    fi
  done <<< "$staged_hooks"
fi

# Gate 3b. New lib/ files MUST NOT break symlink architecture
staged_lib_new=$(git diff --cached --name-only --diff-filter=A -- 'lib/*.py' || true)
if [ -n "$staged_lib_new" ]; then
  while IFS= read -r libfile; do
    [ -z "$libfile" ] && continue
    # Check if there's a corresponding file in packages/ (should be symlinked, not duplicated)
    basename_py=$(basename "$libfile")
    pkg_match=$(find "$COS_ROOT/packages" -name "$basename_py" -not -path "*/__pycache__/*" 2>/dev/null | head -1)
    if [ -n "$pkg_match" ] && [ ! -L "$COS_ROOT/$libfile" ]; then
      echo "WARNING: $libfile exists in packages/ but is NOT a symlink"
      echo "  lib/ files should be symlinks to packages/*/lib/. Check architecture."
      warnings=$((warnings + 1))
    fi
  done <<< "$staged_lib_new"
fi

# Gate 3c. New skills MUST have SKILL.md
staged_skill_dirs=$(git diff --cached --name-only --diff-filter=A -- '.cognitive-os/skills/*' || true)
if [ -n "$staged_skill_dirs" ]; then
  # Extract unique skill directory names
  skill_dirs=$(printf '%s\n' "$staged_skill_dirs" | sed -nE 's#^(.cognitive-os/skills/[^/]+).*#\1#p' | sort -u || true)
  while IFS= read -r skilldir; do
    [ -z "$skilldir" ] && continue
    if [ ! -f "$COS_ROOT/$skilldir/SKILL.md" ]; then
      echo "WARNING: Skill directory $skilldir has no SKILL.md"
      warnings=$((warnings + 1))
    fi
  done <<< "$skill_dirs"
fi

# Gate 3d. settings.json should not be edited directly (use apply-efficiency-profile.sh)
staged_settings=$(git diff --cached --name-only -- '.claude/settings.json' || true)
if [ -n "$staged_settings" ]; then
  # Check if apply-efficiency-profile.sh was also modified (legitimate regeneration)
  staged_profile=$(git diff --cached --name-only -- 'scripts/apply-efficiency-profile.sh' || true)
  if [ -z "$staged_profile" ]; then
    echo "WARNING: .claude/settings.json modified directly without updating scripts/apply-efficiency-profile.sh"
    echo "  Hooks in settings.json are regenerated by: bash scripts/apply-efficiency-profile.sh"
    echo "  Add your hooks to the script first, then regenerate."
    warnings=$((warnings + 1))
  fi
fi

# Gate 3e. Workflow YAMLs must parse (advisory — warn only)
staged_workflows=$(git diff --cached --name-only --diff-filter=ACM -- '.cognitive-os/workflows/*.yaml' '.cognitive-os/workflows/*.yml' || true)
if [ -n "$staged_workflows" ]; then
  while IFS= read -r wf; do
    [ -z "$wf" ] && continue
    [ ! -f "$wf" ] && continue
    if ! python3 -c "import yaml; yaml.safe_load(open('$wf'))" 2>/dev/null; then
      echo "WARNING: Workflow $wf has invalid YAML"
      python3 -c "import yaml; yaml.safe_load(open('$wf'))" 2>&1 || true
      warnings=$((warnings + 1))
    fi
  done <<< "$staged_workflows"
fi

# Gate 3f. New test files must not be purely structural
# Carve-out: if the entire staged diff consists only of SCOPE-tag lines
# (# SCOPE: ... or <!-- SCOPE: ... -->), skip the structural check — these
# lines carry no behavior and the mutation gate adds no signal for them.
#
# Smoke-test (do NOT run during a scope-tag-only commit itself):
#   echo '# SCOPE: both' >> hooks/some-hook.sh
#   git add hooks/some-hook.sh
#   bash .githooks/pre-commit   # should emit [mutation-gate] scope-tag-only commit: skipping structural check
#   git reset HEAD hooks/some-hook.sh
#   git checkout -- hooks/some-hook.sh
_scope_only_commit=false
_added_lines=$(git diff --cached --unified=0 | grep '^+' | grep -v '^+++' || true)
if [ -n "$_added_lines" ]; then
  _non_scope=$(echo "$_added_lines" | grep -vE '^\+[[:space:]]*(#[[:space:]]*SCOPE:[[:space:]]*(os-only|project|both)[[:space:]]*|<!--[[:space:]]*SCOPE:[[:space:]]*(os-only|project|both)[[:space:]]*-->)[[:space:]]*$' || true)
  if [ -z "$_non_scope" ]; then
    _scope_only_commit=true
  fi
fi

# Gate 3f uses `git diff --cached --name-only --diff-filter=A` to build an
# explicit list of NEWLY STAGED test files, then passes that list directly to
# check_test_quality.py.  The script NEVER auto-scans the working tree; it only
# examines the files handed to it.  Untracked files are invisible to this gate.
staged_tests_new=$(git diff --cached --name-only --diff-filter=A -- 'tests/*.py' 'tests/**/*.py' 2>/dev/null || true)
if [ -n "$staged_tests_new" ]; then
  if [ "$_scope_only_commit" = true ]; then
    echo "[mutation-gate] scope-tag-only commit: skipping structural check" >&2
  else
    # Pass the staged file list explicitly — no working-tree scan.
    # shellcheck disable=SC2086
    if python3 "$COS_ROOT/scripts/check_test_quality.py" $staged_tests_new 2>/dev/null; then
      : # tests have behavioral assertions
    else
      echo "BLOCKED: New test file(s) contain only structural assertions (path.exists, is_file, 'in content')."
      echo "  Add assertions that test return values, side effects, or error handling."
      echo "  See docs/testing/mutation-testing.md for guidance."
      exit 1
    fi
  fi
fi

if [ "$warnings" -gt 0 ]; then
  echo ""
  echo "Pre-commit: $warnings consistency warning(s). Review above before pushing."
fi
