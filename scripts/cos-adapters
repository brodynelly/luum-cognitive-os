#!/usr/bin/env python3
# SCOPE: both
"""Consumer UX for ADR-256/258 adapter surfaces."""
from __future__ import annotations

import argparse
import json
import sys
from datetime import datetime, timezone
from pathlib import Path
from typing import Any

ROOT = Path(__file__).resolve().parents[1]
if str(ROOT) not in sys.path:
    sys.path.insert(0, str(ROOT))

from lib.adapter_compile import compile_adapter


def _load_json(path: Path) -> dict[str, Any]:
    if not path.exists():
        return {}
    data = json.loads(path.read_text(encoding="utf-8"))
    return data if isinstance(data, dict) else {}


def _profiles(root: Path) -> list[dict[str, Any]]:
    profiles_dir = root / ".ai" / "profiles"
    rows = []
    for path in sorted(profiles_dir.glob("*.json")):
        data = _load_json(path)
        if data:
            rows.append(data)
    return rows


def list_adapters(root: Path) -> dict[str, Any]:
    adapters = []
    for profile in _profiles(root):
        adapter_dir = root / ".ai" / str(profile.get("adapter_directory", ""))
        manifest = adapter_dir / "adapter.json"
        manifest_data = _load_json(manifest)
        adapters.append({
            "harness": profile.get("harness"),
            "display_name": profile.get("display_name"),
            "status": profile.get("status"),
            "proof_level": profile.get("proof_level"),
            "adapter_directory": profile.get("adapter_directory"),
            "adapter_manifest_exists": manifest.exists(),
            "adapter_contract_kind": manifest_data.get("adapter_contract_kind"),
            "native_file_emission": manifest_data.get("native_file_emission"),
            "native_projection_driver": manifest_data.get("native_projection_driver"),
            "compiler_gap_policy": manifest_data.get("compiler_gap_policy"),
            "projected_primitive_count": manifest_data.get("projected_primitive_count", 0),
        })
    return {"schema_version": "cos-adapters-list.v1", "adapter_count": len(adapters), "adapters": adapters}


def verify_adapters(root: Path) -> dict[str, Any]:
    listed = list_adapters(root)
    findings = []
    for adapter in listed["adapters"]:
        if not adapter["adapter_manifest_exists"]:
            findings.append({"severity": "fail", "id": "missing-adapter-manifest", "harness": adapter["harness"]})
        if adapter.get("proof_level") == "structural" and adapter.get("projected_primitive_count", 0) < 0:
            findings.append({"severity": "fail", "id": "invalid-projected-count", "harness": adapter["harness"]})
        if adapter["adapter_manifest_exists"] and adapter.get("adapter_contract_kind") != "declarative-manifest":
            findings.append({"severity": "fail", "id": "adapter-kind-not-declarative", "harness": adapter["harness"]})
        if adapter["adapter_manifest_exists"] and adapter.get("native_file_emission") is not False:
            findings.append({"severity": "fail", "id": "adapter-manifest-must-not-claim-native-emission", "harness": adapter["harness"]})
    return {
        "schema_version": "cos-adapters-verify.v1",
        "status": "fail" if any(f["severity"] == "fail" for f in findings) else "pass",
        "adapter_count": listed["adapter_count"],
        "findings": findings,
    }


def install_adapter(root: Path, harness: str, *, execute: bool) -> dict[str, Any]:
    profiles = {str(row.get("harness")): row for row in _profiles(root)}
    if harness not in profiles:
        return {"schema_version": "cos-adapters-install.v1", "status": "fail", "harness": harness, "reason": "unknown harness"}
    profile = profiles[harness]
    receipt = {
        "schema_version": "cos-adapters-install.v1",
        "status": "planned" if not execute else "installed-overlay-receipt",
        "harness": harness,
        "generated_at": datetime.now(timezone.utc).replace(microsecond=0).isoformat(),
        "adapter_directory": profile.get("adapter_directory"),
        "proof_level": profile.get("proof_level"),
        "note": "This command verifies the generated .ai adapter surface. Host-specific file mutation remains delegated to existing harness projection drivers or a future fidelity-preserving adapter compiler.",
        "native_file_emission": False,
        "compiler_gap_policy": "cos-adapters is non-mutating for native IDE files; use cos-adapters compile or cos_init.py for actual host file projection.",
    }
    if execute:
        metrics = root / ".cognitive-os" / "metrics"
        metrics.mkdir(parents=True, exist_ok=True)
        with (metrics / "adapter-install-receipts.jsonl").open("a", encoding="utf-8") as handle:
            handle.write(json.dumps(receipt, sort_keys=True) + "\n")
    return receipt


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--project-dir", type=Path, default=Path.cwd())
    parser.add_argument("command", choices=["list", "verify", "install", "compile"])
    parser.add_argument("harness", nargs="?")
    parser.add_argument("--execute", action="store_true")
    parser.add_argument("--output", type=Path)
    parser.add_argument("--mode", choices=["default", "full"], default="default")
    parser.add_argument("--dry-run", action="store_true")
    parser.add_argument("--json", action="store_true")
    args = parser.parse_args()
    root = args.project_dir.resolve()
    if args.command == "list":
        report = list_adapters(root)
    elif args.command == "verify":
        report = verify_adapters(root)
    elif args.command == "install":
        if not args.harness:
            parser.error("install requires HARNESS")
        report = install_adapter(root, args.harness, execute=args.execute)
    else:
        if not args.harness:
            parser.error("compile requires HARNESS")
        if not args.output:
            parser.error("compile requires --output DIR")
        report = compile_adapter(root=root, harness=args.harness, output_dir=args.output, mode=args.mode, dry_run=args.dry_run)
    if args.json:
        print(json.dumps(report, indent=2, sort_keys=True))
    else:
        if args.command == "list":
            print(f"adapters: {report['adapter_count']}")
            for row in report["adapters"]:
                print(f"- {row['harness']}: {row['status']} proof={row['proof_level']} primitives={row['projected_primitive_count']}")
        else:
            print(f"{args.command}: {report.get('status')} harness={report.get('harness', '*')}")
    return 0 if report.get("status") != "fail" else 1


if __name__ == "__main__":
    raise SystemExit(main())
