{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .cognitive-os/hooks/session-init.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "bash .cognitive-os/hooks/subagent-capability-preflight.sh"
          },
          {
            "type": "command",
            "command": "bash .cognitive-os/hooks/clarification-gate.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .cognitive-os/hooks/error-pipeline.sh"
          },
          {
            "type": "command",
            "command": "bash .cognitive-os/hooks/result-truncator.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .cognitive-os/hooks/secret-detector.sh"
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "bash .cognitive-os/hooks/completion-gate.sh"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .cognitive-os/hooks/pre-compaction-flush.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .cognitive-os/hooks/session-cleanup.sh"
          }
        ]
      }
    ]
  }
}
