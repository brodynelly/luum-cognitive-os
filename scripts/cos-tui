#!/usr/bin/env python3
# SCOPE: both
"""Operable terminal surface for Cognitive OS primitive coverage reports."""
from __future__ import annotations

import argparse
import json
import subprocess
import sys
from datetime import datetime, timezone
from pathlib import Path
from typing import Any

RECEIPT_SCHEMA = "cos-tui-action-receipt.v1"
RECEIPT_PATH = Path(".cognitive-os/metrics/tui-actions.jsonl")
WHITELISTED_ACTIONS = {
    "refresh-coverage": [["python3", "scripts/primitive_harness_coverage.py", "--project-dir", "."]],
    "refresh-partials": [["python3", "scripts/primitive_harness_partials.py", "--project-dir", "."]],
    "refresh-all": [
        ["python3", "scripts/primitive_harness_coverage.py", "--project-dir", "."],
        ["python3", "scripts/primitive_harness_partials.py", "--project-dir", "."],
    ],
}


def _root(path: str) -> Path:
    return Path(path).resolve()


def _load(path: Path) -> dict[str, Any]:
    return json.loads(path.read_text(encoding="utf-8"))


def _now() -> str:
    return datetime.now(timezone.utc).isoformat().replace("+00:00", "Z")


def _receipt(root: Path, *, action: str, outcome: str, commands: list[list[str]], details: dict[str, Any] | None = None) -> dict[str, Any]:
    return {
        "schema_version": RECEIPT_SCHEMA,
        "timestamp": _now(),
        "surface_kind": "ui",
        "surface_id": "tui",
        "mode": "operable",
        "action": action,
        "outcome": outcome,
        "project_dir": str(root),
        "commands": commands,
        "whitelisted": action in WHITELISTED_ACTIONS,
        "details": details or {},
    }


def _append_receipt(root: Path, receipt: dict[str, Any]) -> Path:
    path = root / RECEIPT_PATH
    path.parent.mkdir(parents=True, exist_ok=True)
    with path.open("a", encoding="utf-8") as fh:
        fh.write(json.dumps(receipt, sort_keys=True) + "\n")
    return path



def _load_receipts(root: Path) -> list[dict[str, Any]]:
    path = root / RECEIPT_PATH
    if not path.exists():
        return []
    receipts: list[dict[str, Any]] = []
    for raw in path.read_text(encoding="utf-8").splitlines():
        if not raw.strip():
            continue
        try:
            receipt = json.loads(raw)
        except json.JSONDecodeError:
            continue
        if receipt.get("schema_version") != RECEIPT_SCHEMA:
            continue
        receipts.append(receipt)
    return receipts


def _receipt_stats(root: Path) -> dict[str, Any]:
    receipts = _load_receipts(root)
    by_action: dict[str, int] = {}
    by_outcome: dict[str, int] = {}
    for receipt in receipts:
        action = str(receipt.get("action") or "unknown")
        outcome = str(receipt.get("outcome") or "unknown")
        by_action[action] = by_action.get(action, 0) + 1
        by_outcome[outcome] = by_outcome.get(outcome, 0) + 1
    return {
        "schema_version": "cos-tui-action-receipt-stats.v1",
        "receipt_schema_version": RECEIPT_SCHEMA,
        "path": str(RECEIPT_PATH),
        "total": len(receipts),
        "by_action": dict(sorted(by_action.items())),
        "by_outcome": dict(sorted(by_outcome.items())),
        "last_receipt": receipts[-1] if receipts else None,
    }


def _receipts_report(root: Path, *, json_output: bool) -> tuple[int, str]:
    stats = _receipt_stats(root)
    if json_output:
        return 0, json.dumps(stats, indent=2, sort_keys=True) + "\n"
    lines = [
        "Cognitive OS — TUI Action Receipts",
        "",
        f"Receipts: {stats['path']}",
        f"Total: {stats['total']}",
        "",
        "By action:",
    ]
    for action, count in stats["by_action"].items():
        lines.append(f"- {action}: {count}")
    lines.extend(["", "By outcome:"])
    for outcome, count in stats["by_outcome"].items():
        lines.append(f"- {outcome}: {count}")
    if stats.get("last_receipt"):
        lines.extend(["", f"Last action: {stats['last_receipt'].get('action')} ({stats['last_receipt'].get('outcome')})"])
    return 0, "\n".join(lines) + "\n"

def _snapshot(root: Path) -> tuple[int, str]:
    coverage_path = root / "docs" / "reports" / "primitive-harness-coverage-latest.json"
    partials_path = root / "docs" / "reports" / "primitive-harness-partials-latest.json"
    if not coverage_path.exists():
        return 2, "Primitive surface coverage report missing. Run: python3 scripts/primitive_harness_coverage.py --project-dir .\n"
    coverage = _load(coverage_path)
    partials = _load(partials_path) if partials_path.exists() else {"summary": {}}
    summary = coverage.get("summary", {})
    surface_counts = summary.get("surface_projected_or_wired") or summary.get("harness_projected_or_wired") or {}
    surfaces = {item.get("surface_id"): item.get("surface_kind") for item in coverage.get("surfaces", [])}

    lines = [
        "Cognitive OS — Primitive Surface Coverage",
        "Mode: operable (whitelisted actions only)",
        "",
        f"Total primitives: {summary.get('total_primitives', 0)}",
        f"Gaps: {summary.get('gaps', 0)}",
        f"Partial: {partials.get('summary', {}).get('partial_count', summary.get('gaps_by_status', {}).get('partial', 0))}",
        f"Unclassified: {summary.get('unclassified_gaps', 0)}",
        "",
        "Surfaces:",
    ]
    for surface_id in sorted(surface_counts):
        kind = surfaces.get(surface_id, "unknown")
        lines.append(f"- {surface_id} ({kind}): {surface_counts[surface_id]} projected/wired")
    lines.extend([
        "",
        "Whitelisted operations:",
        "- refresh-coverage: regenerate primitive surface coverage report",
        "- refresh-partials: regenerate prioritized partials report",
        "- refresh-all: regenerate both reports in order",
        "",
        "Reports:",
        "- docs/reports/primitive-harness-coverage-latest.json",
        "- docs/reports/primitive-harness-partials-latest.json",
        "",
        f"Receipts: {RECEIPT_PATH}",
    ])
    return 0, "\n".join(lines) + "\n"


def _validate_project(root: Path) -> None:
    if not root.exists() or not root.is_dir():
        raise ValueError(f"project root does not exist: {root}")
    for rel in {part for commands in WHITELISTED_ACTIONS.values() for command in commands for part in command if part.startswith("scripts/")}:
        path = root / rel
        if not path.is_file():
            raise ValueError(f"required whitelisted script is missing: {rel}")


def _operate(root: Path, action: str, *, confirm: bool, dry_run: bool) -> tuple[int, str]:
    commands = WHITELISTED_ACTIONS.get(action)
    if commands is None:
        return 2, f"Unsupported TUI operation: {action}. Allowed: {', '.join(sorted(WHITELISTED_ACTIONS))}\n"
    if not confirm and not dry_run:
        return 2, "Refusing operable TUI action without --confirm. Use --dry-run to inspect the whitelist.\n"
    try:
        _validate_project(root)
    except ValueError as exc:
        return 2, f"TUI safety gate failed: {exc}\n"
    if dry_run:
        receipt = _receipt(root, action=action, outcome="dry-run", commands=commands)
        _append_receipt(root, receipt)
        return 0, json.dumps(receipt, indent=2, sort_keys=True) + "\n"

    results: list[dict[str, Any]] = []
    for command in commands:
        proc = subprocess.run(command, cwd=root, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE, check=False, timeout=120)
        results.append({
            "command": command,
            "returncode": proc.returncode,
            "stdout_tail": proc.stdout[-1000:],
            "stderr_tail": proc.stderr[-1000:],
        })
        if proc.returncode != 0:
            receipt = _receipt(root, action=action, outcome="failed", commands=commands, details={"results": results})
            path = _append_receipt(root, receipt)
            return proc.returncode or 1, f"TUI operation failed; receipt appended to {path}\n"
    receipt = _receipt(root, action=action, outcome="success", commands=commands, details={"results": results})
    path = _append_receipt(root, receipt)
    return 0, f"TUI operation '{action}' completed; receipt appended to {path}\n"


def main() -> int:
    parser = argparse.ArgumentParser(description="Cognitive OS operable TUI surface")
    parser.add_argument("--snapshot", action="store_true", help="Print a non-interactive snapshot and exit")
    parser.add_argument("--receipts", action="store_true", help="Print TUI action receipt summary")
    parser.add_argument("--json", action="store_true", help="Emit machine-readable JSON for receipt summaries")
    parser.add_argument("--operate", choices=sorted(WHITELISTED_ACTIONS), help="Run a whitelisted observe/report operation")
    parser.add_argument("--confirm", action="store_true", help="Required for mutating operable actions")
    parser.add_argument("--dry-run", action="store_true", help="Emit a receipt without running the operation")
    parser.add_argument("--project-dir", default=".")
    args = parser.parse_args()
    root = _root(args.project_dir)
    if args.snapshot:
        code, output = _snapshot(root)
    elif args.receipts:
        code, output = _receipts_report(root, json_output=args.json)
    elif args.operate:
        code, output = _operate(root, args.operate, confirm=args.confirm, dry_run=args.dry_run)
    else:
        parser.error("use --snapshot, --receipts, or --operate")
    stream = sys.stdout if code == 0 else sys.stderr
    stream.write(output)
    return code


if __name__ == "__main__":
    raise SystemExit(main())
