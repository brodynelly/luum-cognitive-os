#!/usr/bin/env python3
"""Generate/check the Active/Partial ADR backlog ledger."""
from __future__ import annotations

import argparse
import sys
from pathlib import Path
from typing import Any

import yaml

ROOT = Path(__file__).resolve().parents[1]
OUT = ROOT / "docs" / "reports" / "adr-partial-backlog-latest.md"

sys.path.insert(0, str(ROOT))
from scripts.generate_adr_index import adr_paths, row_for, md_escape  # noqa: E402


def _frontmatter(path: Path) -> dict[str, Any]:
    text = path.read_text(encoding="utf-8", errors="replace")
    if not text.startswith("---\n"):
        return {}
    raw = text.split("\n---\n", 1)[0].removeprefix("---\n")
    data = yaml.safe_load(raw) or {}
    return data if isinstance(data, dict) else {}


def _remaining(fm: dict[str, Any]) -> str:
    for key in ("partial_remaining", "remaining_work", "missing_scope"):
        value = fm.get(key)
        if value:
            return str(value)
    return str(fm.get("classification_basis") or "").strip()


def render() -> str:
    rows = []
    for path in sorted(adr_paths()):
        row = row_for(path)
        if row.bucket != "Active" or row.implementation_status not in {"partial", "partial-blocked", "blocked", "deferred"}:
            continue
        fm = _frontmatter(path)
        rows.append((row, fm))

    lines = [
        "# ADR Partial Backlog Ledger",
        "",
        "Generated by `scripts/cos-adr-partial-ledger`. Do not edit by hand.",
        "",
        f"Total open partial/deferred/blocked ADRs: {len(rows)}",
        "",
        "| ADR | Implementation | What remains / basis | In scope? | Follow-up ADR | Owner |",
        "|---|---|---|---|---|---|",
    ]
    for row, fm in rows:
        follow = fm.get("follow_up_adr") or fm.get("follow_up") or ""
        owner = fm.get("owner") or ""
        in_scope = fm.get("remaining_in_scope")
        in_scope_text = "unknown" if in_scope is None else str(in_scope).lower()
        lines.append(
            "| "
            + " | ".join(
                [
                    f"[{row.number}](../adrs/{row.path.name})",
                    md_escape(row.implementation_status),
                    md_escape(_remaining(fm)),
                    md_escape(in_scope_text),
                    md_escape(str(follow)),
                    md_escape(str(owner)),
                ]
            )
            + " |"
        )
    return "\n".join(lines).rstrip() + "\n"


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--check", action="store_true", help="Fail if ledger is stale")
    args = parser.parse_args(argv)
    rendered = render()
    if args.check:
        current = OUT.read_text(encoding="utf-8") if OUT.exists() else ""
        if current != rendered:
            print(f"{OUT.relative_to(ROOT)} is stale; run scripts/cos-adr-partial-ledger")
            return 1
        print(f"{OUT.relative_to(ROOT)} is current")
        return 0
    OUT.parent.mkdir(parents=True, exist_ok=True)
    OUT.write_text(rendered, encoding="utf-8")
    print(f"wrote {OUT.relative_to(ROOT)}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
