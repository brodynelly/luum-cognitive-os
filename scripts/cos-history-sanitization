#!/usr/bin/env python3
"""CLI for ADR-218 history sanitization dry-run and safety checks."""
from __future__ import annotations

import argparse
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
if str(ROOT) not in sys.path:
    sys.path.insert(0, str(ROOT))

from lib.history_sanitization import build_report, dumps_json  # noqa: E402


def main() -> int:
    parser = argparse.ArgumentParser(description="Audit planned pre-public git history sanitization.")
    parser.add_argument("--project-dir", type=Path, default=ROOT)
    parser.add_argument("--dry-run", action="store_true", help="Non-mutating default mode")
    parser.add_argument("--execute", action="store_true", help="Validate execute preconditions; live rewrite is not run by this substrate slice")
    parser.add_argument("--json", action="store_true")
    args = parser.parse_args()
    mode = "execute" if args.execute else "dry-run"
    report = build_report(args.project_dir, mode=mode)
    if args.json:
        print(dumps_json(report))
    else:
        print(f"history sanitization {mode}: {report['status']}")
        for finding in report["findings"][:20]:
            rid = f" {finding.get('rule_id')}:" if finding.get("rule_id") else ""
            print(f"[{finding['severity']}] {finding['code']}:{rid} {finding['message']}")
    if report["status"] == "block":
        return 2
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
