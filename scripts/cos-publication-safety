#!/usr/bin/env python3
# SCOPE: both
"""Run project-configured publication-safety gates and emit a COS receipt."""
from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
if str(ROOT) not in sys.path:
    sys.path.insert(0, str(ROOT))

from lib.publication_safety import (  # noqa: E402
    DEFAULT_RECEIPT,
    build_receipt,
    default_config_for,
    write_receipt,
)


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--project-dir", type=Path, default=Path.cwd())
    parser.add_argument("--config", type=Path, default=None, help="Publication-safety config (.yaml or .json). Defaults to manifests/publication-safety.yaml under project dir.")
    parser.add_argument("--output", type=Path, default=None, help="Receipt output path. Defaults to .cognitive-os/receipts/publication-safety/summary.json under project dir.")
    parser.add_argument("--write-step-logs", action="store_true", help="Persist raw stdout/stderr for each gate under the receipt directory. Use only for local diagnostics.")
    parser.add_argument("--json", action="store_true")
    parser.add_argument("--strict", action="store_true", help="Exit 2 on warn as well as fail.")
    parser.add_argument("--allow-missing-config", action="store_true", help="Return a skipped receipt instead of error when no config exists.")
    return parser


def main(argv: list[str] | None = None) -> int:
    args = build_parser().parse_args(argv)
    project_dir = args.project_dir.resolve()
    config_path = args.config or default_config_for(project_dir)
    if not config_path.is_absolute():
        config_path = (project_dir / config_path).resolve()
    output = args.output or (project_dir / DEFAULT_RECEIPT)
    if not output.is_absolute():
        output = (project_dir / output).resolve()

    if not config_path.exists() and args.allow_missing_config:
        receipt = {
            "schema_version": "publication-safety-receipt/v0",
            "project_dir": str(project_dir),
            "config": str(config_path),
            "status": "skipped",
            "enabled": False,
            "summary": {"total": 0, "pass": 0, "warn": 0, "fail": 0, "required_failed": [], "warnings": []},
            "steps": [],
            "claim": {"public_release_ready": False, "claim_ceiling": "not_evaluated", "reason": "publication_safety_config_missing"},
            "raw_output_policy": "hashes_only_by_default; use --write-step-logs for local diagnostics",
        }
        write_receipt(receipt, output)
    else:
        receipt = build_receipt(project_dir, config_path, write_step_logs=args.write_step_logs, output_path=output)
        write_receipt(receipt, output)

    if args.json:
        print(json.dumps(receipt, indent=2, sort_keys=True))
    else:
        print(f"publication-safety {receipt['status']}: {receipt['summary']}")
        print(f"receipt: {output}")

    status = receipt.get("status")
    if status == "fail":
        return 2
    if args.strict and status in {"warn", "skipped"}:
        return 2
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
