#!/usr/bin/env python3
from __future__ import annotations
import argparse, sys
from pathlib import Path
ROOT=Path(__file__).resolve().parents[1]
if str(ROOT) not in sys.path: sys.path.insert(0,str(ROOT))
from lib.feature_tool_due_diligence import fetch_external_source, repo_root, write_json

def main() -> int:
    p=argparse.ArgumentParser(description="Plan or fetch external source into gitignored ADR-255 cache.")
    p.add_argument("url")
    p.add_argument("--repo", default=".")
    p.add_argument("--manifest", default="manifests/feature-tool-due-diligence.yaml")
    p.add_argument("--execute", action="store_true")
    p.add_argument("--json", action="store_true")
    a=p.parse_args(); root=repo_root(Path(a.repo))
    report=fetch_external_source(root, root/a.manifest if not Path(a.manifest).is_absolute() else Path(a.manifest), a.url, execute=a.execute)
    print(write_json(report), end="")
    return 1 if report["status"] == "block" else 0
if __name__ == "__main__": raise SystemExit(main())
