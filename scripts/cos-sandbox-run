#!/usr/bin/env python3
# SCOPE: os-only
from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT))

from lib.sandbox_adapter import SandboxUnavailable, build_sandbox_command  # noqa: E402


def main() -> int:
    parser = argparse.ArgumentParser(description="Run or print an ADR-232 sandbox-wrapped command.")
    parser.add_argument("--workspace", default=".")
    parser.add_argument("--json", action="store_true")
    parser.add_argument("--dry-run", action="store_true")
    parser.add_argument("--allow-fallback", action="store_true")
    parser.add_argument("--backend", choices=["bubblewrap", "seatbelt", "microvm", "contree"])
    parser.add_argument("--network", action="store_true")
    parser.add_argument("--writable-root", action="append", default=[])
    parser.add_argument("cmd", nargs=argparse.REMAINDER)
    args = parser.parse_args()
    cmd = args.cmd[1:] if args.cmd[:1] == ["--"] else args.cmd
    if not cmd:
        parser.error("command required after --")
    try:
        plan = build_sandbox_command(cmd, workspace=args.workspace, backend=args.backend, network=args.network, writable_roots=args.writable_root or None, allow_fallback=args.allow_fallback)
    except SandboxUnavailable as exc:
        if args.json:
            print(json.dumps({"schema_version": "sandbox-adapter/v1", "status": "unavailable", "error": str(exc)}))
        else:
            print(str(exc), file=sys.stderr)
        return 2
    if args.json or args.dry_run:
        print(json.dumps(plan.to_dict(), sort_keys=True))
        return 0
    import subprocess
    proc = subprocess.run(plan.command, cwd=str(Path(args.workspace).resolve()), timeout=30)  # timeout per ADR-278 (default - review)
    return proc.returncode


if __name__ == "__main__":
    raise SystemExit(main())
