#!/usr/bin/env python3
# SCOPE: os-only
from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
if str(ROOT) not in sys.path:
    sys.path.insert(0, str(ROOT))

from lib.dspy_pilot import build_pilot_report

parser = argparse.ArgumentParser(description="Probe the optional DSPy structured-skill pilot")
parser.add_argument("--target-skill", default="sdd-verify")
args = parser.parse_args()
print(json.dumps(build_pilot_report(args.target_skill).to_dict(), indent=2, sort_keys=True))
